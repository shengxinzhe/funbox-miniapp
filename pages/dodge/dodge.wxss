.page {
  min-height: 100vh;
  background: #F5F5F7;
  opacity: 0;
  transition: opacity 0.4s ease;
  overflow: hidden;
}
.fade-in { opacity: 1; }

/* Intro */
.intro {
  text-align: center;
  padding: 60rpx 32rpx 0;
}
.intro-emoji {
  font-size: 120rpx;
  animation: targetBounce 1.2s ease-in-out infinite;
}
@keyframes targetBounce {
  0%,100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.1); }
}
.intro-title {
  font-size: 48rpx; font-weight: 800;
  color: #1D1D1F;
  margin-top: 16rpx;
}
.intro-subtitle {
  font-size: 28rpx; color: #5856D6;
  margin-top: 8rpx; font-weight: 500;
}
.intro-desc {
  font-size: 26rpx; color: #86868B;
  margin-top: 24rpx; line-height: 1.6;
  padding: 0 32rpx;
}
.intro-stats {
  margin-top: 32rpx;
  display: flex; align-items: baseline;
  justify-content: center; gap: 8rpx;
}
.stats-label { font-size: 26rpx; color: #86868B; }
.stats-val { font-size: 48rpx; font-weight: 800; color: #5856D6; }
.start-btn {
  margin-top: 48rpx;
  display: inline-block;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff;
  font-size: 34rpx; font-weight: 700;
  padding: 28rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(88,86,214,0.3);
}
.start-btn:active { transform: scale(0.95); opacity: 0.9; }

/* HUD */
.hud {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.hud-score {
  font-size: 40rpx; font-weight: 800;
  color: #5856D6;
  font-variant-numeric: tabular-nums;
}
.hud-level {
  font-size: 26rpx; font-weight: 600;
  color: #AF52DE;
  background: rgba(175,82,222,0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* Canvas */
.dodge-canvas {
  display: block;
  background: #FFFFFF;
}

/* Result */
.result {
  text-align: center;
  padding: 60rpx 32rpx 0;
}
.result-emoji {
  font-size: 120rpx;
  animation: explode 0.5s ease;
}
@keyframes explode {
  0% { transform: scale(0) rotate(-20deg); }
  60% { transform: scale(1.3) rotate(5deg); }
  100% { transform: scale(1) rotate(0deg); }
}
.result-title {
  font-size: 44rpx; font-weight: 800;
  color: #1D1D1F;
  margin-top: 16rpx;
}

/* Stats */
.result-stats {
  display: flex; justify-content: center;
  gap: 48rpx; margin-top: 40rpx;
}
.stat-item {
  text-align: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.stat-val {
  font-size: 44rpx; font-weight: 800;
  color: #5856D6;
}
.stat-label {
  font-size: 24rpx; color: #86868B;
  margin-top: 4rpx;
}

/* Rank */
.result-rank {
  margin-top: 32rpx;
  font-size: 30rpx; font-weight: 600;
  color: #AF52DE;
  background: rgba(175,82,222,0.08);
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
}

/* Actions */
.result-actions {
  display: flex; justify-content: center;
  align-items: center; gap: 24rpx;
  margin-top: 40rpx;
}
.action-btn {
  font-size: 30rpx; font-weight: 600;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
}
.retry-btn {
  background: #FFFFFF;
  color: #1D1D1F;
  border: 2rpx solid rgba(0,0,0,0.1);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.retry-btn:active { background: #F5F5F7; }
.share-btn {
  background: linear-gradient(135deg, #5856D6, #AF52DE) !important;
  color: #fff !important;
  margin: 0; min-height: 0;
  line-height: 1.5;
}
.share-btn::after { border: none; }

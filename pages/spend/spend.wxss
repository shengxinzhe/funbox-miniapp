.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* Gates header */
.gates-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #14141f, #1a1a2e);
}

.gates-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(108, 99, 255, 0.4);
  flex-shrink: 0;
}

.gates-info {
  margin-left: 24rpx;
}

.gates-name {
  font-size: 36rpx;
  font-weight: 700;
}

.gates-net {
  font-size: 26rpx;
  color: #27ae60;
  margin-top: 4rpx;
}

/* Money bar */
.money-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: linear-gradient(135deg, #1a1a2e, #14141f);
  padding: 24rpx 32rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.money-label {
  font-size: 22rpx;
  color: #8888a0;
}

.money-amount {
  font-size: 64rpx;
  font-weight: 800;
  color: #27ae60;
  font-variant-numeric: tabular-nums;
  transition: transform 0.15s ease;
}

.money-unit {
  font-size: 26rpx;
  font-weight: 400;
  color: #8888a0;
  margin-left: 8rpx;
}

@keyframes money-bounce {
  0% { transform: scale(1); }
  50% { transform: scale(1.06); color: #ff6584; }
  100% { transform: scale(1); }
}

.money-bounce {
  animation: money-bounce 0.3s ease;
}

/* Progress bar */
.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6c63ff, #ff6584);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.money-spent {
  font-size: 22rpx;
  color: #ff6584;
  margin-top: 8rpx;
}

/* Items */
.items {
  padding: 20rpx 32rpx;
}

@keyframes slide-in {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.item {
  display: flex;
  align-items: center;
  background: #14141f;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 14rpx;
  transition: transform 0.15s ease;
}

.item:active {
  transform: scale(0.98);
}

.item-emoji {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  font-size: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.item-info {
  flex: 1;
  margin-left: 18rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
}

.item-price {
  font-size: 22rpx;
  color: #8888a0;
  margin-top: 4rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.act-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  font-weight: 700;
  transition: transform 0.1s ease;
}

.act-btn:active {
  transform: scale(0.85);
}

.buy {
  background: #27ae60;
  color: #fff;
}

.sell {
  background: #e74c3c;
  color: #fff;
}

.disabled {
  opacity: 0.3;
}

.item-qty {
  min-width: 44rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* Receipt */
.receipt {
  margin: 32rpx;
  background: #14141f;
  border-radius: 20rpx;
  padding: 32rpx;
}

.receipt-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  text-align: center;
}

.receipt-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #8888a0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.receipt-total {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ff6584;
}

.share-btn {
  margin-top: 24rpx;
  background: rgba(108, 99, 255, 0.12);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.25);
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.share-btn::after { border: none; }

/* 关注智变纪 */
.follow-hint {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: #8888a0;
  opacity: 0.8;
}

.page {
  min-height: 100vh;
  padding: 0 32rpx 60rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* Intro */
.intro { text-align: center; padding-top: 60rpx; }
.intro-emoji {
  font-size: 120rpx;
  animation: lockPulse 1.5s ease-in-out infinite;
}
@keyframes lockPulse {
  0%,100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.1) rotate(-5deg); }
  75% { transform: scale(1.1) rotate(5deg); }
}
.intro-title {
  font-size: 48rpx; font-weight: 800;
  margin-top: 16rpx;
}
.intro-subtitle {
  font-size: 28rpx; color: #f39c12;
  margin-top: 8rpx; font-weight: 500;
}
.intro-desc {
  font-size: 26rpx; color: #8888a0;
  margin-top: 24rpx; line-height: 1.6;
  padding: 0 32rpx;
}
.intro-stats {
  margin-top: 32rpx;
  display: flex; align-items: baseline;
  justify-content: center; gap: 8rpx;
}
.stats-label { font-size: 26rpx; color: #8888a0; }
.stats-val { font-size: 48rpx; font-weight: 800; color: #f39c12; }
.start-btn {
  margin-top: 48rpx;
  display: inline-block;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  font-size: 34rpx; font-weight: 700;
  padding: 28rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(243,156,18,0.4);
}
.start-btn:active { transform: scale(0.95); opacity: 0.9; }

/* Level bar */
.level-bar {
  margin-top: 24rpx; text-align: center;
}
.level-dots {
  display: flex; justify-content: center; gap: 8rpx;
  margin-bottom: 8rpx;
}
.level-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
}
.dot-pass { background: #22c55e; box-shadow: 0 0 8rpx rgba(34,197,94,0.5); }
.dot-fail { background: #e74c3c; }
.dot-locked { background: #2a2a3e; }
.level-text { font-size: 24rpx; color: #8888a0; }

/* Input */
.input-wrap {
  margin-top: 24rpx;
  background: #14141f;
  border: 2rpx solid #2a2a3e;
  border-radius: 20rpx;
  padding: 24rpx;
  position: relative;
}
.pw-input {
  font-size: 30rpx;
  color: #e0e0f0;
  width: 100%;
  min-height: 48rpx;
}
.pw-length {
  position: absolute;
  right: 24rpx; top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx; color: #555;
}

/* Win */
.win-banner {
  margin-top: 24rpx;
  background: linear-gradient(135deg, rgba(34,197,94,0.15), rgba(243,156,18,0.15));
  border: 2rpx solid rgba(34,197,94,0.3);
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  animation: winGlow 1s ease-in-out infinite alternate;
}
@keyframes winGlow {
  from { box-shadow: 0 0 20rpx rgba(34,197,94,0.2); }
  to { box-shadow: 0 0 40rpx rgba(34,197,94,0.4); }
}
.win-emoji { font-size: 80rpx; }
.win-text {
  font-size: 32rpx; font-weight: 700;
  margin-top: 8rpx; color: #22c55e;
}

/* Result actions */
.result-actions {
  display: flex; justify-content: center;
  align-items: center; gap: 24rpx;
  margin-top: 24rpx;
}
.action-btn {
  font-size: 28rpx; font-weight: 600;
  padding: 20rpx 40rpx;
  border-radius: 48rpx;
}
.retry-btn {
  background: #14141f; color: #e0e0f0;
  border: 2rpx solid #2a2a3e;
}
.share-btn {
  background: linear-gradient(135deg, #f39c12, #e67e22) !important;
  color: #fff !important;
  margin: 0; min-height: 0;
  line-height: 1.5;
}
.share-btn::after { border: none; }

/* Rules */
.rules-list {
  margin-top: 24rpx;
  display: flex; flex-direction: column; gap: 12rpx;
}
.rule-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  background: #14141f;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.3s ease;
}
.rule-pass {
  border-left-color: #22c55e;
  opacity: 0.6;
}
.rule-fail {
  border-left-color: #e74c3c;
}
.rule-icon {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  display: flex; justify-content: center; align-items: center;
  font-size: 24rpx; font-weight: 700;
  flex-shrink: 0;
}
.rule-pass .rule-icon {
  background: rgba(34,197,94,0.2); color: #22c55e;
}
.rule-fail .rule-icon {
  background: rgba(231,76,60,0.2); color: #e74c3c;
}
.rule-text {
  font-size: 26rpx; color: #c0c0d0;
  line-height: 1.5; flex: 1;
}
.rule-num {
  font-size: 22rpx; color: #8888a0;
  margin-right: 8rpx;
}

/* Shake animation for failing rule */
.rule-shake {
  animation: ruleShake 0.4s ease;
}
@keyframes ruleShake {
  0%,100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(12rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}
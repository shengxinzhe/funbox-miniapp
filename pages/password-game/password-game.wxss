.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 32rpx 60rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* Intro */
.intro { text-align: center; padding-top: 60rpx; }
.intro-emoji {
  font-size: 120rpx;
  animation: lockPulse 1.5s ease-in-out infinite;
}
@keyframes lockPulse {
  0%,100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.1) rotate(-5deg); }
  75% { transform: scale(1.1) rotate(5deg); }
}
.intro-title {
  font-size: 48rpx; font-weight: 800;
  margin-top: 16rpx;
  color: #1D1D1F;
}
.intro-subtitle {
  font-size: 28rpx;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-top: 8rpx; font-weight: 500;
}
.intro-desc {
  font-size: 26rpx; color: #86868B;
  margin-top: 24rpx; line-height: 1.6;
  padding: 0 32rpx;
}
.intro-stats {
  margin-top: 32rpx;
  display: flex; align-items: baseline;
  justify-content: center; gap: 8rpx;
}
.stats-label { font-size: 26rpx; color: #86868B; }
.stats-val {
  font-size: 48rpx; font-weight: 800;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.start-btn {
  margin-top: 48rpx;
  display: inline-block;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff;
  font-size: 34rpx; font-weight: 700;
  padding: 28rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(88,86,214,0.3);
}
.start-btn:active { transform: scale(0.95); opacity: 0.9; }

/* Level bar */
.level-bar {
  margin-top: 24rpx; text-align: center;
}
.level-dots {
  display: flex; justify-content: center; gap: 8rpx;
  margin-bottom: 8rpx;
}
.level-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
}
.dot-pass { background: #22c55e; box-shadow: 0 0 8rpx rgba(34,197,94,0.5); }
.dot-fail { background: #e74c3c; }
.dot-locked { background: #D1D1D6; }
.level-text { font-size: 24rpx; color: #86868B; }

/* Rules scroll area */
.rules-scroll {
  max-height: calc(100vh - 340rpx);
  margin-top: 24rpx;
}

/* Input */
.input-wrap {
  margin-top: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 20rpx;
  padding: 24rpx;
  position: relative;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.input-fixed {
  position: sticky;
  bottom: 0;
  z-index: 10;
  margin-top: 20rpx;
}
.pw-input {
  font-size: 30rpx;
  color: #1D1D1F;
  width: 100%;
  min-height: 48rpx;
}
.pw-length {
  position: absolute;
  right: 24rpx; top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx; color: #86868B;
}

/* Win */
.win-banner {
  margin-top: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(34,197,94,0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  animation: winGlow 1s ease-in-out infinite alternate;
}
@keyframes winGlow {
  from { box-shadow: 0 0 20rpx rgba(34,197,94,0.15); }
  to { box-shadow: 0 0 40rpx rgba(34,197,94,0.3); }
}
.win-emoji { font-size: 80rpx; }
.win-text {
  font-size: 32rpx; font-weight: 700;
  margin-top: 8rpx; color: #22c55e;
}

/* Result actions */
.result-actions {
  display: flex; justify-content: center;
  align-items: center; gap: 24rpx;
  margin-top: 24rpx;
}
.action-btn {
  font-size: 28rpx; font-weight: 600;
  padding: 20rpx 40rpx;
  border-radius: 48rpx;
}
.retry-btn {
  background: #F5F5F7; color: #1D1D1F;
  border: 2rpx solid #E5E5EA;
}
.share-btn {
  background: linear-gradient(135deg, #5856D6, #AF52DE) !important;
  color: #fff !important;
  margin: 0; min-height: 0;
  line-height: 1.5;
}
.share-btn::after { border: none; }

/* Rules */
.rules-list {
  display: flex; flex-direction: column; gap: 12rpx;
  padding-bottom: 20rpx;
}
.rule-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  border-left: 6rpx solid transparent;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}
.rule-pass {
  border-left-color: #22c55e;
  opacity: 0.7;
}
.rule-fail {
  border-left-color: #e74c3c;
}
.rule-icon {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  display: flex; justify-content: center; align-items: center;
  font-size: 24rpx; font-weight: 700;
  flex-shrink: 0;
}
.rule-pass .rule-icon {
  background: rgba(34,197,94,0.15); color: #22c55e;
}
.rule-fail .rule-icon {
  background: rgba(231,76,60,0.1); color: #e74c3c;
}
.rule-text {
  font-size: 26rpx; color: #1D1D1F;
  line-height: 1.5; flex: 1;
}
.rule-num {
  font-size: 22rpx; color: #86868B;
  margin-right: 8rpx;
}

/* Shake animation for failing rule */
.rule-shake {
  animation: ruleShake 0.4s ease;
}
@keyframes ruleShake {
  0%,100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(12rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}

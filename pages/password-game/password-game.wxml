<view class="page {{fadeIn ? 'fade-in' : ''}}">

  <!-- Intro -->
  <block wx:if="{{phase === 'intro'}}">
    <view class="intro">
      <view class="intro-emoji">🔐</view>
      <view class="intro-title">密码挑战</view>
      <view class="intro-subtitle">设一个让所有规则满意的密码</view>
      <view class="intro-desc">
        看起来简单？每满足一条规则，就会解锁更荒诞的新规则。你的密码必须同时满足所有已解锁的规则。共15关，你能通关吗？
      </view>
      <view class="intro-stats" wx:if="{{bestLevel > 0}}">
        <text class="stats-label">最佳纪录</text>
        <text class="stats-val">{{bestLevel}}</text>
        <text class="stats-label">/ 15 关</text>
      </view>
      <view class="start-btn" bindtap="startGame">开始挑战</view>
    </view>
  </block>

  <!-- Playing -->
  <block wx:if="{{phase === 'playing'}}">
    <view class="playing">
      <!-- Level indicator -->
      <view class="level-bar">
        <view class="level-dots">
          <view wx:for="{{15}}" wx:key="*this"
            class="level-dot {{index < unlockedCount ? (ruleResults[index].pass ? 'dot-pass' : 'dot-fail') : 'dot-locked'}}">
          </view>
        </view>
        <view class="level-text">已解锁 {{unlockedCount}} / 15 关</view>
      </view>

      <!-- Rules list (above input so keyboard doesn't hide them) -->
      <scroll-view class="rules-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <!-- Win banner -->
        <view class="win-banner" wx:if="{{won}}">
          <view class="win-emoji">🎉</view>
          <view class="win-text">恭喜通关！你是密码大师！</view>
          <view class="result-actions">
            <view class="action-btn retry-btn" bindtap="restart">再来一次</view>
            <button class="action-btn share-btn" open-type="share">分享战绩</button>
          </view>
        </view>

        <view class="rules-list">
          <view wx:for="{{ruleResults}}" wx:key="id"
            class="rule-item {{item.pass ? 'rule-pass' : 'rule-fail'}} {{shakeRule === index ? 'rule-shake' : ''}}">
            <view class="rule-icon">{{item.pass ? '✓' : '✗'}}</view>
            <view class="rule-text">
              <text class="rule-num">规则 {{item.id}}</text>
              <text>{{item.text}}</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- Password input (fixed at bottom, above keyboard) -->
      <view class="input-wrap input-fixed">
        <input class="pw-input" value="{{password}}" bindinput="onInput"
          placeholder="输入你的密码..." placeholder-style="color: #86868B;"
          focus="{{phase === 'playing'}}" maxlength="200"
          adjust-position="{{true}}" cursor-spacing="20" />
        <view class="pw-length">{{password.length}} 字符</view>
      </view>
    </view>
  </block>
</view>
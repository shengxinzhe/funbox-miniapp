.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.top-bar {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  padding: 24rpx 48rpx;
  width: 100%;
  box-sizing: border-box;
}

.level-info { text-align: center; }

.label {
  display: block;
  font-size: 22rpx;
  color: #86868B;
}

.value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1D1D1F;
}

.accent { color: #5856D6; }

.status {
  font-size: 30rpx;
  margin-bottom: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  color: #1D1D1F;
}

.status.memorize {
  background: rgba(88, 86, 214, 0.10);
  color: #5856D6;
}

.status.input {
  background: rgba(52, 199, 89, 0.12);
  color: #34C759;
}

.status.fail {
  background: rgba(255, 59, 48, 0.10);
  color: #FF3B30;
}

.status.success {
  background: rgba(52, 199, 89, 0.12);
  color: #34C759;
}

/* Grid */
.grid {
  display: grid;
  gap: 10rpx;
  width: 92vw;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
}

/* Grid animations */
@keyframes grid-shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(12rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}

.shake-anim {
  animation: grid-shake 0.4s ease;
}

@keyframes grid-celebrate {
  0% { transform: scale(1); }
  30% { transform: scale(1.03); }
  60% { transform: scale(0.98); }
  100% { transform: scale(1); }
}

.celebrate-anim {
  animation: grid-celebrate 0.5s ease;
}

/* Cell */
.cell {
  aspect-ratio: 1;
  background: #E5E5EA;
  border-radius: 14rpx;
  transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
}

/* Cell flip animation */
@keyframes cell-flip {
  0% { transform: rotateY(0deg) scale(1); }
  50% { transform: rotateY(90deg) scale(0.9); }
  100% { transform: rotateY(0deg) scale(1); }
}

.cell.flip-in {
  animation: cell-flip 0.35s ease;
}

.cell.highlight {
  background: #5856D6;
  box-shadow: 0 0 24rpx rgba(88, 86, 214, 0.35);
}

@keyframes glow-pulse {
  0%, 100% { box-shadow: 0 0 16rpx rgba(52, 199, 89, 0.4); }
  50% { box-shadow: 0 0 32rpx rgba(52, 199, 89, 0.65); }
}

.cell.correct {
  background: #34C759;
  animation: cell-flip 0.35s ease, glow-pulse 0.8s ease-in-out;
}

@keyframes wrong-flash {
  0% { background: #FF3B30; transform: scale(1); }
  25% { background: #FF6961; transform: scale(1.05); }
  50% { background: #FF3B30; transform: scale(1); }
  75% { background: #FF6961; transform: scale(0.95); }
  100% { background: #FF3B30; transform: scale(1); }
}

.cell.wrong {
  background: #FF3B30;
  animation: wrong-flash 0.5s ease;
}

.cell.reveal {
  background: rgba(88, 86, 214, 0.15);
  border: 2rpx solid #5856D6;
  animation: cell-flip 0.35s ease;
}

.cell.hidden {
  background: #E5E5EA;
}

.cell:active {
  transform: scale(0.92);
}

/* Actions */
.actions {
  margin-top: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary::after { border: none; }

.share-btn {
  margin-top: 24rpx;
  background: rgba(88, 86, 214, 0.08);
  color: #5856D6;
  border: 1rpx solid rgba(88, 86, 214, 0.20);
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.share-btn::after { border: none; }

/* 关注智变纪 */
.follow-hint {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: #86868B;
  opacity: 0.8;
}

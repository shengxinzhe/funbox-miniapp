.page {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.top-bar {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.level-info { text-align: center; }

.label {
  display: block;
  font-size: 22rpx;
  color: #8888a0;
}

.value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.accent { color: #6c63ff; }

.status {
  font-size: 30rpx;
  margin-bottom: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.status.memorize {
  background: rgba(108, 99, 255, 0.15);
  color: #6c63ff;
}

.status.input {
  background: rgba(39, 174, 96, 0.15);
  color: #27ae60;
}

.status.fail {
  background: rgba(231, 76, 60, 0.15);
  color: #e74c3c;
}

.status.success {
  background: rgba(39, 174, 96, 0.15);
  color: #27ae60;
}

/* Grid */
.grid {
  display: grid;
  gap: 10rpx;
  width: 92vw;
  max-width: 686rpx;
  margin-left: auto;
  margin-right: auto;
}

/* Grid animations */
@keyframes grid-shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(12rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}

.shake-anim {
  animation: grid-shake 0.4s ease;
}

@keyframes grid-celebrate {
  0% { transform: scale(1); }
  30% { transform: scale(1.03); }
  60% { transform: scale(0.98); }
  100% { transform: scale(1); }
}

.celebrate-anim {
  animation: grid-celebrate 0.5s ease;
}

/* Cell */
.cell {
  aspect-ratio: 1;
  background: #1a1a2e;
  border-radius: 14rpx;
  transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
}

/* Cell flip animation */
@keyframes cell-flip {
  0% { transform: rotateY(0deg) scale(1); }
  50% { transform: rotateY(90deg) scale(0.9); }
  100% { transform: rotateY(0deg) scale(1); }
}

.cell.flip-in {
  animation: cell-flip 0.35s ease;
}

.cell.highlight {
  background: #6c63ff;
  box-shadow: 0 0 24rpx rgba(108, 99, 255, 0.5);
}

@keyframes glow-pulse {
  0%, 100% { box-shadow: 0 0 16rpx rgba(39, 174, 96, 0.4); }
  50% { box-shadow: 0 0 32rpx rgba(39, 174, 96, 0.7); }
}

.cell.correct {
  background: #27ae60;
  animation: cell-flip 0.35s ease, glow-pulse 0.8s ease-in-out;
}

@keyframes wrong-flash {
  0% { background: #e74c3c; transform: scale(1); }
  25% { background: #ff6b6b; transform: scale(1.05); }
  50% { background: #e74c3c; transform: scale(1); }
  75% { background: #ff6b6b; transform: scale(0.95); }
  100% { background: #e74c3c; transform: scale(1); }
}

.cell.wrong {
  background: #e74c3c;
  animation: wrong-flash 0.5s ease;
}

.cell.reveal {
  background: rgba(108, 99, 255, 0.3);
  border: 2rpx solid #6c63ff;
  animation: cell-flip 0.35s ease;
}

.cell.hidden {
  background: #1a1a2e;
}

.cell:active {
  transform: scale(0.92);
}

/* Actions */
.actions {
  margin-top: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #5a52d5);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary::after { border: none; }

.share-btn {
  margin-top: 24rpx;
  background: rgba(108, 99, 255, 0.12);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.25);
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.share-btn::after { border: none; }

/* 关注智变纪 */
.follow-hint {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: #8888a0;
  opacity: 0.8;
}

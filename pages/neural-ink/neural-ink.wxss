.page {
  min-height: 100vh;
  background: #0a0a0f;
  color: #e8f4ff;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
}

/* ============ HOME SCREEN ============ */
.home-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}
.home-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}
.home-title {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #0ef0c0, #a855f7);
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 8rpx;
}
.home-subtitle {
  font-size: 28rpx;
  color: #8888a0;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}
.home-desc {
  font-size: 24rpx;
  color: #6666a0;
  line-height: 1.6;
  padding: 0 40rpx;
}

/* Section Title */
.section-title {
  font-size: 26rpx;
  color: #0ef0c0;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin: 40rpx 0 20rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #0ef0c0;
}

/* Level List */
.level-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.level-card {
  width: calc(50% - 8rpx);
  background: #14141f;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  border: 1px solid transparent;
  transition: all 0.2s;
}
.level-card.unlocked {
  border-color: rgba(14, 240, 192, 0.15);
}
.level-card.unlocked:active {
  background: #1a1a2e;
  transform: scale(0.97);
}
.level-card.locked {
  opacity: 0.4;
}
.level-num {
  font-size: 22rpx;
  color: #0ef0c0;
  font-family: monospace;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.level-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8f4ff;
  margin-bottom: 8rpx;
}
.level-diff {
  display: flex;
  gap: 6rpx;
}
.diff-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #0ef0c0;
}
.diff-dot.active {
  box-shadow: 0 0 6rpx #0ef0c0;
}
.level-locked {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
}
.lock-icon {
  font-size: 36rpx;
  opacity: 0.5;
}

/* Free Mode Button */
.free-btn, .gallery-btn {
  display: flex;
  align-items: center;
  background: #14141f;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-top: 24rpx;
  border: 1px solid rgba(168, 85, 247, 0.2);
}
.free-btn:active, .gallery-btn:active {
  background: #1a1a2e;
  transform: scale(0.98);
}
.free-icon, .gallery-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}
.free-title, .gallery-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e8f4ff;
}
.free-desc, .gallery-desc {
  font-size: 24rpx;
  color: #8888a0;
  margin-top: 4rpx;
}
.gallery-btn {
  border-color: rgba(14, 240, 192, 0.15);
}

/* ============ PLAYING SCREEN ============ */
.playing-page {
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Top Bar */
.play-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}
.topbar-left {
  width: 80rpx;
}
.back-arrow {
  font-size: 36rpx;
  color: #8888a0;
  font-weight: 600;
}
.topbar-center {
  flex: 1;
  text-align: center;
}
.topbar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e8f4ff;
}
.topbar-right {
  width: 120rpx;
  text-align: right;
  font-size: 24rpx;
  color: #0ef0c0;
  font-family: monospace;
}
.time-display {
  font-size: 28rpx;
}

/* Canvas Container */
.canvas-container {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 16rpx 0;
  box-shadow: 0 0 40rpx rgba(14, 240, 192, 0.15),
              0 0 80rpx rgba(14, 240, 192, 0.05);
}
.canvas-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 24rpx;
  border: 2rpx solid rgba(14, 240, 192, 0.3);
  pointer-events: none;
  box-shadow: inset 0 0 30rpx rgba(14, 240, 192, 0.08);
}

/* Stats Panel */
.stats-panel {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}
.stat-item {
  text-align: center;
}
.stat-label {
  font-size: 20rpx;
  color: #6666a0;
  font-family: monospace;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}
.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  font-family: monospace;
}
.stat-value.cyan { color: #0ef0c0; }
.stat-value.purple { color: #a855f7; }
.stat-value.green { color: #22c55e; }
.stat-value.orange { color: #f59e0b; }

/* Free Mode Controls */
.free-controls {
  width: 100%;
  padding: 20rpx 40rpx;
  box-sizing: border-box;
}
.param-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.param-label {
  font-size: 24rpx;
  color: #8888a0;
  font-family: monospace;
  width: 120rpx;
  flex-shrink: 0;
}
.free-actions {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}
.action-btn {
  font-size: 24rpx;
  color: #0ef0c0;
  background: rgba(14, 240, 192, 0.1);
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(14, 240, 192, 0.3);
}
.action-btn:active {
  background: rgba(14, 240, 192, 0.2);
}

/* Touch Counter */
.touch-counter {
  font-size: 22rpx;
  color: #6666a0;
  font-family: monospace;
  margin: 12rpx 0;
}

/* Finish Button */
.finish-btn {
  background: linear-gradient(135deg, #0ef0c0, #0bbf9a);
  color: #0a0a0f;
  font-size: 30rpx;
  font-weight: 700;
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
  margin: 20rpx 0 40rpx;
  box-shadow: 0 0 30rpx rgba(14, 240, 192, 0.3);
}
.finish-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* Tutorial Toast (non-blocking) */
.tutorial-toast {
  position: fixed;
  bottom: 220rpx;
  left: 50%;
  transform: translateX(-50%) translateY(20rpx);
  opacity: 0;
  transition: all 0.4s ease;
  z-index: 50;
  pointer-events: auto;
}
.tutorial-toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.tutorial-toast-inner {
  display: flex;
  align-items: center;
  background: rgba(20, 20, 31, 0.92);
  border: 1px solid rgba(14, 240, 192, 0.3);
  border-radius: 40rpx;
  padding: 18rpx 36rpx;
  box-shadow: 0 4rpx 30rpx rgba(14, 240, 192, 0.15);
}
.tutorial-toast-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.tutorial-toast-text {
  font-size: 26rpx;
  color: #e8f4ff;
  font-weight: 500;
  white-space: nowrap;
}

/* ============ RESULT SCREEN ============ */
.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}
.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}
.result-grade {
  font-size: 100rpx;
  font-weight: 800;
  font-family: monospace;
  line-height: 1;
  margin-bottom: 12rpx;
}
.grade-S { color: #fbbf24; text-shadow: 0 0 30rpx rgba(251, 191, 36, 0.5); }
.grade-A { color: #0ef0c0; text-shadow: 0 0 30rpx rgba(14, 240, 192, 0.5); }
.grade-B { color: #3b82f6; text-shadow: 0 0 30rpx rgba(59, 130, 246, 0.5); }
.grade-C { color: #a855f7; text-shadow: 0 0 30rpx rgba(168, 85, 247, 0.5); }
.grade-D { color: #8888a0; }
.result-score-label {
  font-size: 24rpx;
  color: #8888a0;
  margin-bottom: 8rpx;
}
.result-score-num {
  font-size: 64rpx;
  font-weight: 700;
  font-family: monospace;
  color: #e8f4ff;
}

/* Specimen Card */
.specimen-card {
  background: #14141f;
  border-radius: 24rpx;
  padding: 36rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1px solid rgba(14, 240, 192, 0.15);
  margin-bottom: 32rpx;
}
.specimen-title {
  font-size: 22rpx;
  color: #0ef0c0;
  letter-spacing: 2rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.specimen-name {
  font-size: 36rpx;
  font-weight: 700;
  font-family: monospace;
  color: #e8f4ff;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}
.specimen-details {
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  padding-top: 20rpx;
}
.specimen-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.specimen-key {
  font-size: 24rpx;
  color: #8888a0;
}
.specimen-val {
  font-size: 24rpx;
  color: #e8f4ff;
  font-family: monospace;
  font-weight: 600;
}

/* Result Actions */
.result-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 24rpx;
}
.result-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.result-btn.secondary {
  background: #1a1a2e;
  color: #8888a0;
  border: 1px solid rgba(255, 255, 255, 0.1);
}
.result-btn.primary {
  background: linear-gradient(135deg, #0ef0c0, #0bbf9a);
  color: #0a0a0f;
}
.result-btn:active {
  transform: scale(0.96);
}

/* Share Button */
.share-btn {
  background: transparent !important;
  color: #0ef0c0 !important;
  font-size: 26rpx !important;
  border: 1px solid rgba(14, 240, 192, 0.3) !important;
  border-radius: 40rpx !important;
  padding: 16rpx 40rpx !important;
  line-height: 1.5 !important;
}
.share-btn::after {
  border: none !important;
}

/* ============ GALLERY SCREEN ============ */
.gallery-page {
  padding-top: 20rpx;
}
.gallery-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}
.gallery-back {
  font-size: 28rpx;
  color: #0ef0c0;
  font-weight: 600;
}
.gallery-title-bar {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8f4ff;
}
.gallery-count {
  font-size: 24rpx;
  color: #8888a0;
  font-family: monospace;
}

/* Specimen List */
.specimen-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.specimen-item {
  display: flex;
  align-items: center;
  background: #14141f;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}
.specimen-item-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.specimen-item-info {
  flex: 1;
}
.specimen-item-name {
  font-size: 28rpx;
  font-weight: 600;
  font-family: monospace;
  color: #e8f4ff;
  margin-bottom: 6rpx;
}
.specimen-item-meta {
  font-size: 22rpx;
  color: #6666a0;
  font-family: monospace;
}
.specimen-item-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #0ef0c0;
  font-family: monospace;
}

/* Gallery Empty */
.gallery-empty {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 30rpx;
  color: #8888a0;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #6666a0;
}

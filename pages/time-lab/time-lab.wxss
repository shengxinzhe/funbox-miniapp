.page {
  min-height: 100vh;
  padding: 0 32rpx 60rpx;
  opacity: 0; transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* HOME */
.home { text-align: center; padding-top: 48rpx; }
.home-icon-wrap {
  width: 120rpx; height: 120rpx; margin: 0 auto 24rpx;
  position: relative;
}
.home-icon {
  width: 100rpx; height: 100rpx;
  border: 4rpx solid #818cf8; border-radius: 50%;
  position: absolute; top: 10rpx; left: 10rpx;
  box-shadow: 0 0 30rpx rgba(129,140,248,0.3);
}
.clock-hand {
  position: absolute; bottom: 50%; left: 50%;
  width: 3rpx; height: 36rpx;
  background: #818cf8; border-radius: 2rpx;
  transform-origin: bottom center;
  animation: tick 4s steps(60) infinite;
}
@keyframes tick {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.home-title { font-size: 48rpx; font-weight: 800; margin-bottom: 6rpx; }
.home-desc { font-size: 26rpx; color: #888; margin-bottom: 32rpx; }

/* Target selector */
.target-select { margin-bottom: 24rpx; }
.target-label { font-size: 24rpx; color: #666; margin-bottom: 12rpx; }
.target-row {
  display: flex; justify-content: center; gap: 16rpx;
}
.target-chip {
  background: #14141f; border: 2rpx solid #222;
  color: #888; font-size: 28rpx; font-weight: 600;
  padding: 16rpx 36rpx; border-radius: 20rpx;
  transition: all 0.2s ease;
}
.chip-active {
  border-color: #818cf8; color: #818cf8;
  background: rgba(129,140,248,0.1);
  box-shadow: 0 0 16rpx rgba(129,140,248,0.25);
}
.best-badge {
  display: inline-block;
  background: rgba(245,158,11,0.1); color: #f59e0b;
  font-size: 24rpx; font-weight: 700;
  padding: 8rpx 28rpx; border-radius: 16rpx;
  margin-bottom: 24rpx;
}
.start-btn {
  display: inline-block;
  background: linear-gradient(135deg, #818cf8, #6366f1);
  color: #fff; font-size: 32rpx; font-weight: 600;
  padding: 28rpx 100rpx; border-radius: 52rpx;
  box-shadow: 0 8rpx 32rpx rgba(129,140,248,0.35);
  margin-bottom: 28rpx;
}
.start-btn:active { transform: scale(0.96); opacity: 0.9; }

/* History */
.history-section { margin-top: 8rpx; }
.history-title { font-size: 24rpx; color: #666; margin-bottom: 12rpx; }
.history-list {
  display: flex; flex-direction: column; gap: 8rpx;
}
.h-item {
  display: flex; justify-content: space-between; align-items: center;
  background: #0f0f1a; border-radius: 12rpx; padding: 12rpx 20rpx;
  font-size: 24rpx;
}
.h-actual { color: #ccc; font-weight: 600; }
.h-err { font-weight: 600; }
.err-good { color: #22c55e; }
.err-ok { color: #f59e0b; }
.err-bad { color: #ef4444; }
.h-score { color: #818cf8; font-weight: 700; }
.back-link { font-size: 26rpx; color: #555; margin-top: 20rpx; }

/* READY */
.ready-screen {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  margin: 0 -32rpx; padding: 0 32rpx;
}
.ready-text { font-size: 32rpx; color: #888; margin-bottom: 8rpx; }
.ready-num {
  font-size: 160rpx; font-weight: 900; color: #818cf8;
  line-height: 1;
  animation: readyPulse 1s ease infinite;
}
@keyframes readyPulse {
  0%,100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.7; }
}
.ready-hint { font-size: 24rpx; color: #555; margin-top: 24rpx; }
.ready-target { font-size: 28rpx; color: #818cf8; font-weight: 600; margin-top: 8rpx; }

/* COUNTING */
.counting-screen {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  margin: 0 -32rpx; padding: 0 32rpx;
  background: #060610;
}
.counting-orb {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(129,140,248,0.15), transparent);
  margin-bottom: 32rpx;
  animation: orbBreathe 6s ease-in-out infinite;
}
@keyframes orbBreathe {
  0%,100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.15); opacity: 0.8; }
}
.counting-text {
  font-size: 36rpx; font-weight: 700; color: #818cf8;
  margin-bottom: 16rpx;
}
.counting-hint { font-size: 26rpx; color: #555; }
.counting-stop {
  font-size: 32rpx; color: #ccc; font-weight: 600;
  margin-top: 48rpx; padding: 24rpx 60rpx;
  border: 2rpx solid #333; border-radius: 40rpx;
  animation: stopGlow 2s ease infinite;
}
@keyframes stopGlow {
  0%,100% { border-color: #333; }
  50% { border-color: #818cf8; box-shadow: 0 0 20rpx rgba(129,140,248,0.2); }
}

/* RESULT */
.result { text-align: center; padding-top: 48rpx; }
.result-ring {
  width: 180rpx; height: 180rpx; margin: 0 auto 24rpx;
  border-radius: 50%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  animation: ringAppear 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
}
@keyframes ringAppear {
  from { opacity: 0; transform: scale(0.6); }
  to { opacity: 1; transform: scale(1); }
}
.ring-great {
  border: 8rpx solid #22c55e;
  box-shadow: 0 0 40rpx rgba(34,197,94,0.3);
}
.ring-ok {
  border: 8rpx solid #f59e0b;
  box-shadow: 0 0 40rpx rgba(245,158,11,0.3);
}
.ring-low {
  border: 8rpx solid #ef4444;
  box-shadow: 0 0 40rpx rgba(239,68,68,0.3);
}
.ring-score {
  font-size: 56rpx; font-weight: 900; line-height: 1;
}
.ring-great .ring-score { color: #22c55e; }
.ring-ok .ring-score { color: #f59e0b; }
.ring-low .ring-score { color: #ef4444; }
.ring-label { font-size: 22rpx; color: #888; }

/* Compare */
.result-compare {
  display: flex; align-items: center; justify-content: center;
  gap: 24rpx; margin-bottom: 24rpx;
}
.compare-item { text-align: center; }
.cmp-num { font-size: 40rpx; font-weight: 800; color: #ccc; }
.cmp-actual { color: #818cf8; }
.cmp-label { font-size: 22rpx; color: #666; }
.compare-arrow { font-size: 36rpx; color: #444; }

/* Error bar */
.error-bar-wrap { margin: 0 40rpx 20rpx; }
.error-bar {
  height: 10rpx; background: #1a1a2e; border-radius: 5rpx;
  overflow: hidden; margin-bottom: 8rpx;
}
.error-fill {
  height: 100%; border-radius: 5rpx;
  transition: width 0.8s ease;
}
.fill-great { background: linear-gradient(90deg, #22c55e, #86efac); }
.fill-ok { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.fill-bad { background: linear-gradient(90deg, #ef4444, #f87171); }
.error-text { font-size: 24rpx; color: #888; }

/* Insight */
.insight-card {
  background: rgba(129,140,248,0.08);
  border-radius: 16rpx; padding: 20rpx 28rpx;
  font-size: 26rpx; color: #a5b4fc;
  margin: 16rpx 20rpx 28rpx;
}

/* Actions */
.result-actions {
  display: flex; gap: 24rpx; justify-content: center;
  margin-bottom: 16rpx;
}
.retry-btn {
  background: rgba(129,140,248,0.15); color: #818cf8;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx 44rpx; border-radius: 44rpx;
}
.retry-btn:active { opacity: 0.7; }
.change-btn {
  background: rgba(255,255,255,0.06); color: #aaa;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx 44rpx; border-radius: 44rpx;
}
.change-btn:active { opacity: 0.7; }
.share-btn {
  display: inline-block;
  background: linear-gradient(135deg, #818cf8, #6366f1);
  color: #fff !important; font-size: 28rpx; font-weight: 600;
  padding: 24rpx 60rpx; border-radius: 44rpx;
  line-height: 1.5; border: none; margin-bottom: 8rpx;
}
.share-btn::after { border: none; }
.share-btn:active { opacity: 0.9; }

<view class="page {{fadeIn ? 'fade-in' : ''}}">

  <!-- Intro: fake CAPTCHA checkbox -->
  <block wx:if="{{phase === 'intro'}}">
    <view class="intro">
      <view class="intro-emoji">🤖</view>
      <view class="intro-title">我不是机器人</view>
      <view class="intro-subtitle">证明你是人类</view>
      <view class="intro-desc">
        完成一系列验证挑战，包括数学题、图案识别、规律推理等。答对越多分数越高，连续答对有额外加分。得分50+即可通过人类验证。
      </view>
      <view class="intro-stats" wx:if="{{bestScore > 0}}">
        <text class="stats-label">最高分</text>
        <text class="stats-val">{{bestScore}}</text>
      </view>

      <!-- Fake CAPTCHA -->
      <view class="captcha-box" bindtap="tapCheckbox">
        <view class="captcha-checkbox {{checkboxChecked ? 'checked' : ''}}">
          <view class="check-mark" wx:if="{{checkboxChecked}}">✓</view>
        </view>
        <view class="captcha-label">我不是机器人</view>
        <view class="captcha-logo">
          <view class="logo-shield">🛡️</view>
          <view class="logo-text">reCAPTCHA</view>
        </view>
      </view>
    </view>
  </block>

  <!-- Playing -->
  <block wx:if="{{phase === 'playing'}}">
    <view class="playing">
      <!-- Header -->
      <view class="play-header">
        <view class="play-progress">{{current + 1}} / {{total}}</view>
        <view class="play-score">得分: {{score}}</view>
        <view class="play-timer">{{timerText}}</view>
      </view>
      <view class="combo-badge" wx:if="{{combo >= 2}}">
        🔥 x{{combo}} 连击
      </view>

      <!-- Challenge card -->
      <view class="challenge-card {{cardAnim}}">
        <view class="ch-title">{{challenge.title}}</view>

        <!-- Math / Sequence -->
        <block wx:if="{{challenge.type === 'math' || challenge.type === 'sequence'}}">
          <view class="ch-question">{{challenge.question}}</view>
          <view class="ch-options">
            <view wx:for="{{challenge.options}}" wx:key="*this"
              class="ch-opt {{answered && item === challenge.answer ? 'opt-correct' : ''}} {{answered && selected[0] === item && item !== challenge.answer ? 'opt-wrong' : ''}} {{!answered ? 'opt-default' : ''}}"
              bindtap="selectOption" data-val="{{item}}">
              {{item}}
            </view>
          </view>
        </block>

        <!-- Emoji grid -->
        <block wx:if="{{challenge.type === 'emoji'}}">
          <view class="emoji-grid">
            <view wx:for="{{challenge.grid}}" wx:key="*this"
              class="emoji-cell {{selected.indexOf('' + index) >= 0 ? 'cell-selected' : ''}}"
              bindtap="selectOption" data-val="{{'' + index}}">
              {{item}}
            </view>
          </view>
          <view class="submit-emoji" wx:if="{{!answered}}" bindtap="submitEmoji">确认选择</view>
          <view class="emoji-result" wx:if="{{answered}}">
            <text class="{{correct ? 'res-correct' : 'res-wrong'}}">{{correct ? '选对了！' : '没选对...'}}</text>
          </view>
        </block>

        <!-- Color count -->
        <block wx:if="{{challenge.type === 'colorcount'}}">
          <view class="color-grid">
            <view wx:for="{{challenge.grid}}" wx:key="*this" class="color-cell">{{item}}</view>
          </view>
          <view class="ch-options">
            <view wx:for="{{challenge.options}}" wx:key="*this"
              class="ch-opt {{answered && item === challenge.answer ? 'opt-correct' : ''}} {{answered && selected[0] === item && item !== challenge.answer ? 'opt-wrong' : ''}} {{!answered ? 'opt-default' : ''}}"
              bindtap="selectOption" data-val="{{item}}">
              {{item}}
            </view>
          </view>
        </block>

        <!-- Rotate text -->
        <block wx:if="{{challenge.type === 'rotate'}}">
          <view class="rotate-box">
            <text class="rotate-word" style="transform: rotate({{challenge.rotation}}deg);">{{challenge.word}}</text>
          </view>
          <view class="ch-options">
            <view wx:for="{{challenge.options}}" wx:key="*this"
              class="ch-opt {{answered && item === challenge.answer ? 'opt-correct' : ''}} {{answered && selected[0] === item && item !== challenge.answer ? 'opt-wrong' : ''}} {{!answered ? 'opt-default' : ''}}"
              bindtap="selectOption" data-val="{{item}}">
              {{item}}
            </view>
          </view>
        </block>

        <!-- Feedback -->
        <view class="feedback" wx:if="{{answered && challenge.type !== 'emoji'}}">
          <text class="{{correct ? 'res-correct' : 'res-wrong'}}">{{correct ? '正确！' : '错误'}}</text>
        </view>

        <view class="next-btn" wx:if="{{answered}}" bindtap="nextChallenge">
          {{current < total - 1 ? '下一题' : '查看结果'}}
        </view>
      </view>
    </view>
  </block>

  <!-- Result -->
  <block wx:if="{{phase === 'result'}}">
    <view class="result">
      <view class="result-stamp {{verified ? 'stamp-pass' : 'stamp-fail'}}">
        {{verified ? '✓ 人类' : '✗ 机器人'}}
      </view>
      <view class="result-title">{{verified ? '验证通过' : '验证失败'}}</view>
      <view class="result-subtitle">{{verified ? '恭喜！你已被确认为人类' : '抱歉，系统判定你可能是机器人'}}</view>

      <view class="result-stats">
        <view class="stat-item">
          <view class="stat-val">{{score}}</view>
          <view class="stat-label">总分</view>
        </view>
        <view class="stat-item">
          <view class="stat-val">{{maxCombo}}</view>
          <view class="stat-label">最大连击</view>
        </view>
        <view class="stat-item">
          <view class="stat-val">{{timerText}}</view>
          <view class="stat-label">用时</view>
        </view>
      </view>

      <view class="result-actions">
        <view class="action-btn retry-btn" bindtap="restart">重新验证</view>
        <button class="action-btn share-btn" open-type="share">分享结果</button>
      </view>
    </view>
  </block>
</view>
.page {
  min-height: 100vh;
  padding: 0 32rpx 60rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* Intro */
.intro { text-align: center; padding-top: 60rpx; }
.intro-emoji {
  font-size: 120rpx;
  animation: robotBlink 2s ease-in-out infinite;
}
@keyframes robotBlink {
  0%,45%,55%,100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.intro-title {
  font-size: 48rpx; font-weight: 800;
  margin-top: 16rpx;
}
.intro-subtitle {
  font-size: 28rpx; color: #3498db;
  margin-top: 8rpx; font-weight: 500;
}
.intro-desc {
  font-size: 26rpx; color: #8888a0;
  margin-top: 24rpx; line-height: 1.6;
  padding: 0 32rpx;
}
.intro-stats {
  margin-top: 24rpx;
  display: flex; align-items: baseline;
  justify-content: center; gap: 8rpx;
}
.stats-label { font-size: 26rpx; color: #8888a0; }
.stats-val { font-size: 48rpx; font-weight: 800; color: #3498db; }

/* Fake CAPTCHA */
.captcha-box {
  margin: 48rpx auto 0;
  width: 540rpx;
  background: #f9f9f9;
  border: 2rpx solid #d3d3d3;
  border-radius: 8rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.captcha-checkbox {
  width: 48rpx; height: 48rpx;
  border: 4rpx solid #c1c1c1;
  border-radius: 4rpx;
  display: flex; justify-content: center; align-items: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}
.captcha-checkbox.checked {
  background: #4caf50;
  border-color: #4caf50;
  animation: checkPop 0.3s ease;
}
@keyframes checkPop {
  0% { transform: scale(0.8); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.check-mark {
  color: #fff; font-size: 28rpx; font-weight: 700;
}
.captcha-label {
  flex: 1;
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
  text-align: left;
}
.captcha-logo {
  display: flex; flex-direction: column;
  align-items: center;
}
.logo-shield { font-size: 36rpx; }
.logo-text { font-size: 18rpx; color: #999; margin-top: 2rpx; }

/* Playing */
.playing { padding-top: 16rpx; }
.play-header {
  display: flex; justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}
.play-progress { font-size: 26rpx; color: #8888a0; }
.play-score { font-size: 28rpx; font-weight: 700; color: #3498db; }
.play-timer { font-size: 26rpx; color: #8888a0; font-variant-numeric: tabular-nums; }
.combo-badge {
  text-align: center;
  font-size: 28rpx; font-weight: 700;
  color: #f39c12;
  margin-bottom: 8rpx;
  animation: comboPop 0.3s ease;
}
@keyframes comboPop {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* Challenge card */
.challenge-card {
  background: #14141f;
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  opacity: 0;
  transform: translateY(30rpx);
}
.card-enter {
  animation: cardSlide 0.4s ease forwards;
}
@keyframes cardSlide {
  to { opacity: 1; transform: translateY(0); }
}
.ch-title {
  font-size: 30rpx; font-weight: 600;
  text-align: center; color: #e0e0f0;
  margin-bottom: 24rpx;
}
.ch-question {
  font-size: 52rpx; font-weight: 800;
  text-align: center; color: #fff;
  margin-bottom: 32rpx;
  font-variant-numeric: tabular-nums;
}

/* Options grid */
.ch-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.ch-opt {
  text-align: center;
  font-size: 32rpx; font-weight: 600;
  padding: 28rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}
.opt-default {
  background: #1a1a2e;
  border: 2rpx solid #2a2a3e;
  color: #c0c0d0;
}
.opt-default:active { background: #222240; }
.opt-correct {
  background: rgba(34,197,94,0.2);
  border: 2rpx solid #22c55e;
  color: #22c55e;
  animation: correctFlash 0.3s ease;
}
@keyframes correctFlash {
  0% { transform: scale(0.95); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}
.opt-wrong {
  background: rgba(231,76,60,0.2);
  border: 2rpx solid #e74c3c;
  color: #e74c3c;
  animation: wrongShake 0.4s ease;
}
@keyframes wrongShake {
  0%,100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

/* Emoji grid */
.emoji-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.emoji-cell {
  font-size: 48rpx;
  text-align: center;
  padding: 20rpx 0;
  background: #1a1a2e;
  border: 2rpx solid #2a2a3e;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}
.emoji-cell:active { transform: scale(0.95); }
.cell-selected {
  background: rgba(52,152,219,0.2);
  border-color: #3498db;
  box-shadow: 0 0 12rpx rgba(52,152,219,0.3);
}
.submit-emoji {
  text-align: center;
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  font-size: 28rpx; font-weight: 600;
  padding: 20rpx 0;
  border-radius: 40rpx;
}
.submit-emoji:active { opacity: 0.85; }
.emoji-result {
  text-align: center;
  margin-top: 12rpx;
}

/* Color grid */
.color-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.color-cell {
  font-size: 40rpx;
  text-align: center;
  padding: 16rpx 0;
}

/* Rotate */
.rotate-box {
  width: 200rpx; height: 200rpx;
  margin: 0 auto 32rpx;
  display: flex; justify-content: center; align-items: center;
  background: #1a1a2e;
  border-radius: 20rpx;
}
.rotate-word {
  font-size: 56rpx; font-weight: 800;
  color: #e0e0f0;
  display: inline-block;
}

/* Feedback */
.feedback {
  text-align: center;
  margin-top: 16rpx;
  font-size: 28rpx; font-weight: 600;
}
.res-correct { color: #22c55e; }
.res-wrong { color: #e74c3c; }

/* Next */
.next-btn {
  margin-top: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  font-size: 30rpx; font-weight: 600;
  padding: 24rpx 0;
  border-radius: 48rpx;
  animation: btnAppear 0.3s ease forwards;
}
@keyframes btnAppear {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.next-btn:active { opacity: 0.85; }

/* Result */
.result { text-align: center; padding-top: 60rpx; }
.result-stamp {
  display: inline-block;
  font-size: 44rpx; font-weight: 900;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  border: 6rpx solid;
  transform: rotate(-5deg);
  animation: stampSlam 0.4s ease;
}
@keyframes stampSlam {
  0% { transform: rotate(-5deg) scale(2); opacity: 0; }
  60% { transform: rotate(-5deg) scale(0.9); }
  100% { transform: rotate(-5deg) scale(1); opacity: 1; }
}
.stamp-pass {
  color: #22c55e;
  border-color: #22c55e;
  background: rgba(34,197,94,0.1);
}
.stamp-fail {
  color: #e74c3c;
  border-color: #e74c3c;
  background: rgba(231,76,60,0.1);
}
.result-title {
  font-size: 40rpx; font-weight: 800;
  margin-top: 32rpx;
}
.result-subtitle {
  font-size: 28rpx; color: #8888a0;
  margin-top: 8rpx;
}

/* Stats */
.result-stats {
  display: flex; justify-content: center;
  gap: 48rpx; margin-top: 40rpx;
}
.stat-item { text-align: center; }
.stat-val {
  font-size: 44rpx; font-weight: 800;
  color: #3498db;
}
.stat-label {
  font-size: 24rpx; color: #8888a0;
  margin-top: 4rpx;
}

/* Actions */
.result-actions {
  display: flex; justify-content: center;
  align-items: center; gap: 24rpx;
  margin-top: 40rpx;
}
.action-btn {
  font-size: 30rpx; font-weight: 600;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
}
.retry-btn {
  background: #14141f; color: #e0e0f0;
  border: 2rpx solid #2a2a3e;
}
.retry-btn:active { background: #1a1a2e; }
.share-btn {
  background: linear-gradient(135deg, #3498db, #2980b9) !important;
  color: #fff !important;
  margin: 0; min-height: 0;
  line-height: 1.5;
}
.share-btn::after { border: none; }
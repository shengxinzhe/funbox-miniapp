.page {
  min-height: 100vh;
  padding: 0 32rpx 60rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* ===== Intro ===== */
.intro {
  text-align: center;
  padding-top: 80rpx;
}
.intro-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}
.icon-ai {
  width: 120rpx; height: 120rpx;
  background: linear-gradient(135deg, #6c63ff, #a855f7);
  border-radius: 28rpx;
  font-size: 44rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(108,99,255,0.3);
}
.icon-vs {
  font-size: 36rpx; font-weight: 700; color: #555;
}
.icon-human {
  width: 120rpx; height: 120rpx;
  background: linear-gradient(135deg, #f97316, #ef4444);
  border-radius: 28rpx;
  font-size: 44rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(249,115,22,0.3);
}
.intro-title {
  font-size: 52rpx; font-weight: 800;
  margin-bottom: 20rpx;
}
.intro-desc {
  font-size: 28rpx; color: #8888a0;
  line-height: 1.6;
  padding: 0 40rpx;
  margin-bottom: 48rpx;
}
.intro-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-bottom: 60rpx;
}
.stat-item { text-align: center; }
.stat-num {
  font-size: 48rpx; font-weight: 700; color: #6c63ff;
}
.stat-label {
  font-size: 24rpx; color: #666; margin-top: 4rpx;
}
.start-btn {
  display: inline-block;
  background: linear-gradient(135deg, #6c63ff, #a855f7);
  color: #fff;
  font-size: 32rpx; font-weight: 600;
  padding: 28rpx 100rpx;
  border-radius: 52rpx;
  box-shadow: 0 8rpx 32rpx rgba(108,99,255,0.35);
}
.start-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* ===== Playing ===== */
.play-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 12rpx;
}
.progress-text {
  font-size: 28rpx; color: #8888a0; font-weight: 600;
}
.score-display {
  font-size: 28rpx; font-weight: 700; color: #6c63ff;
  transition: transform 0.2s;
}
.score-pop {
  transform: scale(1.3);
}
.progress-bar {
  height: 6rpx; background: #1a1a2e;
  border-radius: 3rpx; margin-bottom: 24rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6c63ff, #a855f7);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

.combo-badge {
  text-align: center;
  font-size: 26rpx; font-weight: 700;
  color: #f59e0b;
  margin-bottom: 12rpx;
  animation: comboPulse 0.5s ease;
}
@keyframes comboPulse {
  0% { transform: scale(0.8); opacity: 0; }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

.theme-badge {
  display: inline-block;
  background: rgba(108,99,255,0.12);
  color: #a78bfa;
  font-size: 24rpx; font-weight: 600;
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.question-text {
  font-size: 34rpx; font-weight: 700;
  margin-bottom: 28rpx;
  line-height: 1.4;
}

/* Options */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.option-card {
  position: relative;
  background: #14141f;
  border: 2rpx solid #222238;
  border-radius: 24rpx;
  padding: 32rpx;
  transition: all 0.25s ease;
}
.option-card:active {
  transform: scale(0.98);
}
.option-card.correct {
  border-color: #22c55e;
  background: rgba(34,197,94,0.08);
}
.option-card.wrong {
  border-color: #ef4444;
  background: rgba(239,68,68,0.08);
}
.option-label {
  display: inline-block;
  width: 52rpx; height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: rgba(108,99,255,0.15);
  color: #a78bfa;
  font-size: 28rpx; font-weight: 700;
  border-radius: 14rpx;
  margin-bottom: 16rpx;
}
.option-desc {
  font-size: 30rpx; line-height: 1.6; color: #ccc;
}
.ai-tag {
  display: inline-block;
  margin-top: 16rpx;
  background: linear-gradient(135deg, #6c63ff, #a855f7);
  color: #fff;
  font-size: 22rpx; font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}
.human-tag {
  display: inline-block;
  margin-top: 16rpx;
  background: linear-gradient(135deg, #f97316, #ef4444);
  color: #fff;
  font-size: 22rpx; font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

/* Shake */
.shake {
  animation: shakeAnim 0.4s ease;
}
@keyframes shakeAnim {
  0%,100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(12rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}

/* Particles */
.particle {
  position: fixed;
  background: #6c63ff;
  border-radius: 50%;
  opacity: 0;
  animation: particlePop 0.7s ease-out forwards;
  pointer-events: none;
}
@keyframes particlePop {
  0% { opacity: 1; transform: scale(0) translateY(0); }
  50% { opacity: 0.8; transform: scale(1.2) translateY(-60rpx); }
  100% { opacity: 0; transform: scale(0.5) translateY(-140rpx); }
}

/* Explain */
.explain-box {
  margin-top: 28rpx;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.explain-correct {
  background: rgba(34,197,94,0.08);
  border: 1rpx solid rgba(34,197,94,0.2);
}
.explain-wrong {
  background: rgba(239,68,68,0.08);
  border: 1rpx solid rgba(239,68,68,0.2);
}
.explain-header {
  font-size: 30rpx; font-weight: 700;
  margin-bottom: 12rpx;
}
.explain-correct .explain-header { color: #22c55e; }
.explain-wrong .explain-header { color: #ef4444; }
.explain-text {
  font-size: 26rpx; color: #999; line-height: 1.6;
  margin-bottom: 20rpx;
}
.next-btn {
  display: inline-block;
  background: rgba(108,99,255,0.15);
  color: #a78bfa;
  font-size: 28rpx; font-weight: 600;
  padding: 16rpx 52rpx;
  border-radius: 32rpx;
}
.next-btn:active {
  opacity: 0.7;
}

/* ===== Result ===== */
.result {
  text-align: center;
  padding-top: 60rpx;
}
.result-score-ring {
  width: 200rpx; height: 200rpx;
  margin: 0 auto 32rpx;
  border: 8rpx solid #6c63ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(108,99,255,0.25);
  animation: ringPulse 1.5s ease infinite;
}
@keyframes ringPulse {
  0%,100% { box-shadow: 0 0 40rpx rgba(108,99,255,0.25); }
  50% { box-shadow: 0 0 60rpx rgba(108,99,255,0.4); }
}
.ring-text {
  font-size: 48rpx; font-weight: 800; color: #6c63ff;
}
.result-title {
  font-size: 44rpx; font-weight: 800;
  margin-bottom: 16rpx;
}
.result-desc {
  font-size: 28rpx; color: #8888a0;
  line-height: 1.6;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}
.result-stats {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 48rpx;
}
.rstat { text-align: center; }
.rstat-num {
  font-size: 40rpx; font-weight: 700; color: #fff;
}
.rstat-label {
  font-size: 22rpx; color: #666; margin-top: 4rpx;
}
.result-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 32rpx;
}
.retry-btn {
  background: rgba(108,99,255,0.15);
  color: #a78bfa;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx 48rpx;
  border-radius: 44rpx;
}
.retry-btn:active { opacity: 0.7; }
.share-result-btn {
  display: inline-block;
  background: linear-gradient(135deg, #6c63ff, #a855f7);
  color: #fff !important;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx 48rpx;
  border-radius: 44rpx;
  line-height: 1.5;
  border: none;
}
.share-result-btn::after { border: none; }
.share-result-btn:active { opacity: 0.9; }
.back-link {
  font-size: 26rpx; color: #555;
  margin-top: 12rpx;
}

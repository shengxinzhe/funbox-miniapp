<view class="page {{fadeIn ? 'fade-in' : ''}}">

  <!-- Intro -->
  <block wx:if="{{phase === 'intro'}}">
    <view class="intro">
      <view class="intro-icon">
        <view class="icon-ai">AI</view>
        <view class="icon-vs">VS</view>
        <view class="icon-human">人</view>
      </view>
      <view class="intro-title">谁画的？</view>
      <view class="intro-desc">
        每道题展示两种画作描述，一幅由AI生成，一幅由人类创作。
        你能分辨出哪个是AI的作品吗？
      </view>
      <view class="intro-stats">
        <view class="stat-item">
          <view class="stat-num">{{total}}</view>
          <view class="stat-label">道题目</view>
        </view>
        <view class="stat-item">
          <view class="stat-num">30</view>
          <view class="stat-label">题库总量</view>
        </view>
      </view>
      <view class="start-btn" bindtap="startGame">开始鉴别</view>
    </view>
  </block>

  <!-- Playing -->
  <block wx:if="{{phase === 'playing'}}">
    <!-- Header bar -->
    <view class="play-header">
      <view class="progress-text">{{current + 1}} / {{total}}</view>
      <view class="score-display {{scoreAnim ? 'score-pop' : ''}}">
        得分 {{score}}
      </view>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{(current + 1) / total * 100}}%"></view>
    </view>

    <!-- Combo -->
    <view wx:if="{{combo >= 2}}" class="combo-badge">
      连对 {{combo}} 题!
    </view>

    <!-- Theme -->
    <view class="theme-badge">主题: {{currentQ.theme}}</view>

    <!-- Question -->
    <view class="question-text">以下哪个是AI生成的作品？</view>

    <!-- Options -->
    <view class="options">
      <view
        class="option-card {{chosen === 'A' ? (isCorrect ? 'correct' : 'wrong') : (chosen && currentQ.answer === 'A' ? 'correct' : '')}} {{shakeA ? 'shake' : ''}}"
        bindtap="choose"
        data-choice="A"
      >
        <view class="option-label">A</view>
        <view class="option-desc">{{currentQ.descA}}</view>
        <view wx:if="{{chosen && currentQ.answer === 'A'}}" class="ai-tag">AI 作品</view>
        <view wx:if="{{chosen && currentQ.answer !== 'A'}}" class="human-tag">人类作品</view>
      </view>

      <view
        class="option-card {{chosen === 'B' ? (isCorrect ? 'correct' : 'wrong') : (chosen && currentQ.answer === 'B' ? 'correct' : '')}} {{shakeB ? 'shake' : ''}}"
        bindtap="choose"
        data-choice="B"
      >
        <view class="option-label">B</view>
        <view class="option-desc">{{currentQ.descB}}</view>
        <view wx:if="{{chosen && currentQ.answer === 'B'}}" class="ai-tag">AI 作品</view>
        <view wx:if="{{chosen && currentQ.answer !== 'B'}}" class="human-tag">人类作品</view>
      </view>
    </view>

    <!-- Particles -->
    <view wx:for="{{particles}}" wx:key="id"
      class="particle"
      style="left:{{item.x}}rpx; top:{{item.y}}rpx; width:{{item.size}}rpx; height:{{item.size}}rpx; animation-delay:{{item.delay}}ms;">
    </view>

    <!-- Explain -->
    <view wx:if="{{showExplain}}" class="explain-box {{isCorrect ? 'explain-correct' : 'explain-wrong'}}">
      <view class="explain-header">
        <text>{{isCorrect ? '回答正确!' : '回答错误'}}</text>
      </view>
      <view class="explain-text">{{currentQ.explain}}</view>
      <view class="next-btn" bindtap="nextQuestion">
        {{current + 1 >= total ? '查看结果' : '下一题'}}
      </view>
    </view>
  </block>

  <!-- Result -->
  <block wx:if="{{phase === 'result'}}">
    <view class="result">
      <view class="result-score-ring">
        <view class="ring-text">{{score}}/{{total}}</view>
      </view>
      <view class="result-title">
        {{score >= total * 0.9 ? 'AI鉴赏大师' : (score >= total * 0.7 ? 'AI观察者' : (score >= total * 0.5 ? 'AI入门学徒' : 'AI小白鼠'))}}
      </view>
      <view class="result-desc">
        {{score >= total * 0.9 ? '你对AI生成内容有着敏锐的洞察力，几乎不会被AI"骗到"！' : (score >= total * 0.7 ? '你有不错的AI鉴别能力，但偶尔还是会被AI迷惑。' : (score >= total * 0.5 ? '你对AI和人类作品有基本的区分能力，继续练习吧！' : 'AI的作品完全把你迷住了！在AI时代，提升鉴别力很重要哦。'))}}
      </view>

      <view class="result-stats">
        <view class="rstat">
          <view class="rstat-num">{{score}}</view>
          <view class="rstat-label">答对</view>
        </view>
        <view class="rstat">
          <view class="rstat-num">{{total - score}}</view>
          <view class="rstat-label">答错</view>
        </view>
        <view class="rstat">
          <view class="rstat-num">{{maxCombo}}</view>
          <view class="rstat-label">最大连对</view>
        </view>
      </view>

      <view class="result-actions">
        <view class="retry-btn" bindtap="restart">再玩一次</view>
        <button class="share-result-btn" open-type="share">分享战绩</button>
      </view>
      <view class="back-link" bindtap="backToHome">返回首页</view>
    </view>
  </block>

</view>

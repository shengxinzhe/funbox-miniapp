<view class="page">

  <!-- HOME PHASE -->
  <block wx:if="{{phase === 'home'}}">
    <view class="home-container fade-in">
      <view class="home-header">
        <view class="game-title">闪数挑战</view>
        <view class="game-subtitle">数感实验</view>
      </view>
      <view class="info-card slide-up">
        <view class="info-text">屏幕上会短暂闪现一组随机圆点，凭直觉估计你看到了几个。</view>
        <view class="info-text">这项实验来自认知科学中的数感研究——人类大脑能不依赖逐一计数而快速感知数量。</view>
        <view class="info-row">
          <view class="info-badge">10 轮</view>
          <view class="info-badge">满分 1000</view>
          <view class="info-badge">越来越难</view>
        </view>
      </view>
      <view class="best-score-wrap" wx:if="{{bestScore > 0}}">
        <view class="best-label">历史最佳</view>
        <view class="best-value">{{bestScore}}</view>
      </view>
      <button class="btn-primary" bindtap="startGame">开始实验</button>
    </view>
  </block>

  <!-- READY PHASE (countdown) -->
  <block wx:if="{{phase === 'ready'}}">
    <view class="ready-container">
      <view class="countdown-label">准备好了吗</view>
      <view class="countdown-number {{countdownAnim}}">{{countdownNum}}</view>
      <view class="countdown-hint">即将闪现圆点</view>
    </view>
  </block>

  <!-- FLASH PHASE -->
  <block wx:if="{{phase === 'flash'}}">
    <view class="flash-container">
      <view class="round-indicator">第 {{currentRound}} / {{totalRounds}} 轮</view>
      <view class="canvas-wrap">
        <canvas type="2d" id="flashCanvas" class="flash-canvas"></canvas>
      </view>
      <view class="flash-hint">专注观察...</view>
    </view>
  </block>

  <!-- RECALL PHASE (canvas clears, waiting) -->
  <block wx:if="{{phase === 'recall'}}">
    <view class="flash-container">
      <view class="round-indicator">第 {{currentRound}} / {{totalRounds}} 轮</view>
      <view class="canvas-wrap">
        <canvas type="2d" id="flashCanvas" class="flash-canvas"></canvas>
      </view>
      <view class="flash-hint recall-hint">回忆数量...</view>
    </view>
  </block>

  <!-- GUESS PHASE -->
  <block wx:if="{{phase === 'guess'}}">
    <view class="guess-container fade-in">
      <view class="round-indicator">第 {{currentRound}} / {{totalRounds}} 轮</view>
      <view class="guess-question">你看到了几个？</view>
      <view class="guess-display">
        <view class="guess-number {{guessInput === '' ? 'placeholder' : ''}}">{{guessInput === '' ? '?' : guessInput}}</view>
      </view>
      <view class="keypad">
        <view class="keypad-row">
          <button class="key-btn" bindtap="onKeyTap" data-val="1">1</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="2">2</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="3">3</button>
        </view>
        <view class="keypad-row">
          <button class="key-btn" bindtap="onKeyTap" data-val="4">4</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="5">5</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="6">6</button>
        </view>
        <view class="keypad-row">
          <button class="key-btn" bindtap="onKeyTap" data-val="7">7</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="8">8</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="9">9</button>
        </view>
        <view class="keypad-row">
          <button class="key-btn key-back" bindtap="onBackspace">←</button>
          <button class="key-btn" bindtap="onKeyTap" data-val="0">0</button>
          <button class="key-btn key-confirm {{guessInput === '' ? 'disabled' : ''}}" bindtap="onConfirm">确认</button>
        </view>
      </view>
    </view>
  </block>

  <!-- FEEDBACK PHASE -->
  <block wx:if="{{phase === 'feedback'}}">
    <view class="feedback-container fade-in">
      <view class="round-indicator">第 {{currentRound}} / {{totalRounds}} 轮</view>
      <view class="feedback-card {{feedbackClass}}">
        <view class="feedback-row">
          <view class="feedback-label">实际数量</view>
          <view class="feedback-actual">{{actualCount}}</view>
        </view>
        <view class="feedback-divider"></view>
        <view class="feedback-row">
          <view class="feedback-label">你的估计</view>
          <view class="feedback-guess">{{userGuess}}</view>
        </view>
        <view class="feedback-diff" wx:if="{{diffText !== ''}}">{{diffText}}</view>
      </view>
      <view class="points-earned {{feedbackClass}}">+{{pointsEarned}} 分</view>
      <view class="total-score-hint">累计 {{totalScore}} 分</view>
    </view>
  </block>

  <!-- RESULT PHASE -->
  <block wx:if="{{phase === 'result'}}">
    <view class="result-container fade-in">
      <view class="result-header">
        <view class="result-rating-badge {{ratingClass}}">{{rating}}</view>
        <view class="result-rating-label">{{ratingLabel}}</view>
      </view>
      <view class="result-card slide-up">
        <view class="result-row">
          <view class="result-key">最终得分</view>
          <view class="result-val accent">{{totalScore}} <text class="result-unit">/ 1000</text></view>
        </view>
        <view class="result-row">
          <view class="result-key">准确率</view>
          <view class="result-val">{{accuracy}}%</view>
        </view>
        <view class="result-row" wx:if="{{isNewBest}}">
          <view class="result-key">历史最佳</view>
          <view class="result-val new-best">{{bestScore}} NEW</view>
        </view>
        <view class="result-row" wx:else>
          <view class="result-key">历史最佳</view>
          <view class="result-val">{{bestScore}}</view>
        </view>
      </view>
      <view class="result-actions">
        <button class="btn-primary" bindtap="restartGame">再来一次</button>
        <button class="btn-secondary" open-type="share" catchtap="">分享成绩</button>
        <button class="btn-ghost" bindtap="goHome">返回</button>
      </view>
    </view>
  </block>

</view>

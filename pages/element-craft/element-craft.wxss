.page { min-height:100vh; padding:0 32rpx 60rpx; opacity:0; transition:opacity .4s; background:#F5F5F7; }
.fade-in { opacity:1; }

/* Intro */
.intro { text-align:center; padding-top:60rpx; }
.intro-icons { display:flex; align-items:center; justify-content:center; gap:12rpx; margin-bottom:24rpx; }
.el-icon { font-size:56rpx; }
.plus-icon, .equals-icon { font-size:36rpx; color:#5856D6; font-weight:800; }
.intro-title { font-size:48rpx; font-weight:800; color:#1D1D1F; }
.intro-subtitle { font-size:28rpx; color:#5856D6; margin-top:8rpx; }
.intro-desc { font-size:26rpx; color:#86868B; margin-top:24rpx; line-height:1.6; padding:0 32rpx; }
.intro-stats { margin-top:32rpx; display:flex; align-items:baseline; justify-content:center; gap:8rpx; }
.stats-label { font-size:26rpx; color:#86868B; }
.stats-val { font-size:48rpx; font-weight:800; color:#5856D6; }
.start-btn { margin-top:48rpx; display:inline-block; background:linear-gradient(135deg,#5856D6,#AF52DE); color:#fff; font-size:34rpx; font-weight:700; padding:28rpx 100rpx; border-radius:60rpx; box-shadow:0 8rpx 32rpx rgba(88,86,214,.3); }
.start-btn:active { transform:scale(.95); }

/* HUD */
.hud { display:flex; justify-content:space-between; align-items:center; padding:16rpx 0; }
.hud-count { font-size:28rpx; font-weight:700; color:#5856D6; }
.hud-clear { font-size:26rpx; color:#ef4444; padding:8rpx 24rpx; border:2rpx solid rgba(239,68,68,.3); border-radius:24rpx; }

/* Crafting area */
.craft-area { display:flex; align-items:center; justify-content:center; gap:20rpx; padding:32rpx 0; margin:8rpx 0; }
.craft-slot { width:120rpx; height:120rpx; border-radius:24rpx; background:#FFFFFF; border:3rpx dashed #D1D1D6; display:flex; align-items:center; justify-content:center; font-size:56rpx; transition:all .3s; box-shadow:0 1rpx 8rpx rgba(0,0,0,0.04); }
.slot-filled { border-style:solid; border-color:#5856D6; background:rgba(88,86,214,.08); animation:slotPop .3s ease; }
@keyframes slotPop { 0%{transform:scale(.8)} 50%{transform:scale(1.1)} 100%{transform:scale(1)} }
.slot-hint { font-size:40rpx; color:#C7C7CC; }
.craft-plus { font-size:40rpx; color:#5856D6; font-weight:800; }

/* Result overlay */
.result-overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,.4); display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:100; opacity:0; pointer-events:none; transition:opacity .3s; }
.result-overlay.show { opacity:1; pointer-events:auto; }
.result-card { background:#FFFFFF; border:1rpx solid rgba(0,0,0,0.06); border-radius:32rpx; padding:48rpx; text-align:center; width:500rpx; animation:resultBounce .5s ease; box-shadow:0 8rpx 40rpx rgba(0,0,0,0.12); }
@keyframes resultBounce { 0%{transform:scale(.5);opacity:0} 60%{transform:scale(1.05)} 100%{transform:scale(1);opacity:1} }
.result-emoji { font-size:120rpx; }
.result-new { animation:newDiscover .6s ease; }
@keyframes newDiscover { 0%{transform:scale(0) rotate(-180deg)} 60%{transform:scale(1.2) rotate(10deg)} 100%{transform:scale(1) rotate(0)} }
.result-name { font-size:40rpx; font-weight:800; margin-top:12rpx; color:#1D1D1F; }
.result-badge { display:inline-block; font-size:24rpx; font-weight:700; color:#34C759; background:rgba(52,199,89,.12); padding:6rpx 24rpx; border-radius:20rpx; margin-top:12rpx; }
.result-old { color:#86868B; background:rgba(134,134,139,.1); }
.result-fail .result-emoji { font-size:80rpx; }
.result-formula { font-size:28rpx; color:#86868B; margin-top:20rpx; }
.tap-hint { font-size:24rpx; color:#86868B; margin-top:24rpx; }

.hint-text { text-align:center; font-size:24rpx; color:#86868B; margin:8rpx 0; }

/* Element grid */
.element-grid { display:flex; flex-wrap:wrap; gap:16rpx; margin-top:16rpx; justify-content:flex-start; }
.element-item { display:flex; flex-direction:column; align-items:center; justify-content:center; width:calc(25% - 12rpx); aspect-ratio:1; background:#FFFFFF; border:1rpx solid rgba(0,0,0,0.06); border-radius:20rpx; transition:all .15s; animation:elAppear .3s ease backwards; box-shadow:0 1rpx 8rpx rgba(0,0,0,0.04); }
.element-item:active { transform:scale(.92); }
.el-selected { border-color:#5856D6; background:rgba(88,86,214,.08); transform:scale(.95); box-shadow:0 2rpx 12rpx rgba(88,86,214,.2); }
@keyframes elAppear { from{opacity:0;transform:scale(.7)} to{opacity:1;transform:scale(1)} }
.el-emoji { font-size:44rpx; }
.el-name { font-size:20rpx; color:#86868B; margin-top:4rpx; }

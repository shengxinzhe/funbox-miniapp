.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 32rpx 60rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* ===== HOME ===== */
.home { text-align: center; padding-top: 40rpx; }
.home-badge {
  display: inline-block;
  background: rgba(88,86,214,0.10);
  color: #5856D6; font-size: 22rpx; font-weight: 600;
  padding: 8rpx 24rpx; border-radius: 20rpx; margin-bottom: 24rpx;
}
.home-icon-row {
  display: flex; justify-content: center; gap: 32rpx;
  margin-bottom: 24rpx;
}
.home-icon-item {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.home-icon {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
}
/* Icon backgrounds */
.icon-flash { background: rgba(245,158,11,0.12); }
.icon-brain { background: rgba(168,85,247,0.12); }
.icon-grid { background: rgba(59,130,246,0.12); }
.icon-calc { background: rgba(239,68,68,0.12); }
.icon-stroop { background: rgba(236,72,153,0.12); }
.icon-eye { background: rgba(6,182,212,0.12); }
.icon-seq { background: rgba(249,115,22,0.12); }
/* Icon content */
.home-icon::after, .test-icon::after, .bd-icon::after {
  font-size: 28rpx; font-weight: 700;
}
.icon-flash::after { content: '⚡'; }
.icon-brain::after { content: '🧠'; }
.icon-grid::after { content: '▦'; color: #3b82f6; }
.icon-calc::after { content: '±'; color: #ef4444; font-size: 32rpx; }
.icon-stroop::after { content: '彩'; color: #ec4899; font-size: 26rpx; }
.icon-eye::after { content: '👁'; }
.icon-seq::after { content: '◈'; color: #f97316; font-size: 30rpx; }

.home-icon-label { font-size: 20rpx; color: #86868B; }
.home-title {
  font-size: 48rpx; font-weight: 800; color: #1D1D1F; margin-bottom: 4rpx;
}
.home-subtitle {
  font-size: 26rpx; color: #86868B; margin-bottom: 32rpx;
}
.home-streak-card {
  display: inline-flex; align-items: baseline; gap: 8rpx;
  background: rgba(245,158,11,0.08); border-radius: 20rpx;
  padding: 16rpx 36rpx; margin-bottom: 28rpx;
}
.streak-num { font-size: 48rpx; font-weight: 900; color: #f59e0b; }
.streak-label { font-size: 24rpx; color: #f59e0b; }

/* Friend compare on home */
.compare-card {
  background: #FFFFFF; border: 1rpx solid rgba(59,130,246,0.15);
  border-radius: 20rpx; padding: 20rpx 32rpx; margin-bottom: 24rpx;
  display: inline-block;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.compare-title { font-size: 22rpx; color: #3b82f6; }
.compare-score { font-size: 48rpx; font-weight: 900; color: #3b82f6; line-height: 1.2; }
.compare-hint { font-size: 22rpx; color: #86868B; }

.today-done-card { margin-bottom: 20rpx; }
.done-score {
  font-size: 72rpx; font-weight: 900; color: #5856D6; line-height: 1;
}
.done-label { font-size: 24rpx; color: #86868B; margin-bottom: 16rpx; }
.start-btn {
  display: inline-block;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff; font-size: 32rpx; font-weight: 600;
  padding: 28rpx 100rpx; border-radius: 52rpx;
  box-shadow: 0 8rpx 32rpx rgba(88,86,214,0.25);
  margin-bottom: 32rpx;
}
.start-btn:active { transform: scale(0.96); opacity: 0.9; }
.btn-secondary {
  background: rgba(88,86,214,0.10);
  color: #5856D6; box-shadow: none;
}
.history-section { text-align: left; margin-top: 16rpx; }
.history-title {
  font-size: 26rpx; color: #86868B; font-weight: 600;
  margin-bottom: 16rpx; text-align: center;
}
.history-chart {
  display: flex; align-items: flex-end; gap: 8rpx;
  height: 180rpx; padding: 0 8rpx; overflow-x: auto;
}
.chart-bar-wrap {
  display: flex; flex-direction: column; align-items: center;
  flex-shrink: 0; width: 36rpx;
}
.chart-bar {
  width: 24rpx; min-height: 4rpx;
  background: linear-gradient(to top, #5856D6, #AF52DE);
  border-radius: 4rpx 4rpx 0 0; transition: height 0.5s ease;
}
.chart-date {
  font-size: 16rpx; color: #86868B; margin-top: 4rpx;
  writing-mode: vertical-rl; transform: rotate(180deg);
  max-height: 60rpx; overflow: hidden;
}
.back-link { font-size: 26rpx; color: #86868B; margin-top: 20rpx; }

/* ===== TEST PHASE ===== */
.test-progress {
  display: flex; justify-content: space-between;
  padding: 20rpx 8rpx 16rpx; position: relative;
}
.test-progress::before {
  content: ''; position: absolute;
  top: 38rpx; left: 60rpx; right: 60rpx;
  height: 2rpx; background: rgba(0,0,0,0.08);
}
.test-progress-step {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; z-index: 1;
}
.step-dot {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #FFFFFF; border: 2rpx solid rgba(0,0,0,0.10);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #86868B; font-weight: 700;
  transition: all 0.3s ease;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.step-current {
  border-color: #5856D6; color: #5856D6;
  box-shadow: 0 0 16rpx rgba(88,86,214,0.25);
}
.step-done {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  border-color: #5856D6; color: #fff;
}
.step-name { font-size: 20rpx; color: #86868B; }

/* Test card */
.test-card {
  background: #FFFFFF; border-radius: 24rpx;
  padding: 32rpx; margin-top: 12rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  opacity: 0; transform: translateX(40rpx);
}
.test-slide-in {
  animation: slideIn 0.4s ease forwards;
}
@keyframes slideIn {
  from { opacity: 0; transform: translateX(40rpx); }
  to { opacity: 1; transform: translateX(0); }
}
.test-header {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 24rpx;
}
.test-icon {
  width: 48rpx; height: 48rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
}
.test-title { font-size: 34rpx; font-weight: 700; color: #1D1D1F; }
.test-badge {
  font-size: 22rpx; color: #86868B; background: rgba(0,0,0,0.05);
  padding: 4rpx 16rpx; border-radius: 12rpx; margin-left: auto;
}
.test-score-display {
  font-size: 28rpx; color: #5856D6; font-weight: 600; margin-top: 12rpx;
}

/* ===== REACTION ===== */
.reaction-area {
  height: 400rpx; border-radius: 24rpx;
  background: #F5F5F7;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  transition: background 0.15s ease;
}
.reaction-go { animation: goPulse 0.6s ease infinite; }
@keyframes goPulse {
  0%,100% { box-shadow: 0 0 0 rgba(88,86,214,0); }
  50% { box-shadow: 0 0 60rpx rgba(88,86,214,0.3); }
}
.reaction-early { animation: shakeX 0.4s ease; }
@keyframes shakeX {
  0%,100% { transform: translateX(0); }
  20%,60% { transform: translateX(-12rpx); }
  40%,80% { transform: translateX(12rpx); }
}
.reaction-hint { font-size: 32rpx; font-weight: 700; color: #86868B; }
.reaction-go-text { color: #1D1D1F; font-size: 48rpx; }
.reaction-sub { font-size: 24rpx; color: #86868B; margin-top: 8rpx; }
.reaction-time-inline { font-size: 44rpx; font-weight: 800; color: #f59e0b; }
.reaction-result { text-align: center; padding: 24rpx 0; }
.reaction-time-big { font-size: 80rpx; font-weight: 900; color: #f59e0b; line-height: 1; }
.reaction-unit { font-size: 26rpx; color: #86868B; }

/* ===== MEMORY ===== */
.memory-level { font-size: 24rpx; color: #86868B; margin-bottom: 20rpx; }
.memory-digits-display {
  display: flex; justify-content: center; gap: 16rpx;
  margin: 32rpx 0;
}
.memory-digit {
  font-size: 56rpx; font-weight: 800; color: #a855f7;
  background: rgba(168,85,247,0.08);
  width: 72rpx; height: 88rpx; line-height: 88rpx;
  text-align: center; border-radius: 16rpx;
  transition: all 0.3s ease;
}
.digit-show {
  opacity: 1; transform: scale(1);
  animation: digitReveal 0.3s ease;
}
.digit-hide {
  opacity: 0.12; transform: scale(0.85);
  color: transparent; background: rgba(168,85,247,0.04);
}
@keyframes digitReveal {
  from { opacity: 0; transform: scale(0.5) translateY(10rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
.memory-hint { font-size: 24rpx; color: #86868B; text-align: center; }
.memory-input-area {
  display: flex; gap: 16rpx; margin: 24rpx 0;
}
.memory-input {
  flex: 1; background: #F5F5F7; border: 2rpx solid rgba(0,0,0,0.10);
  border-radius: 16rpx; padding: 20rpx 24rpx;
  color: #1D1D1F; font-size: 36rpx; font-weight: 700;
  text-align: center; letter-spacing: 8rpx;
}
.memory-submit {
  background: #a855f7; color: #fff;
  padding: 20rpx 36rpx; border-radius: 16rpx;
  font-size: 28rpx; font-weight: 600;
  display: flex; align-items: center;
}
.memory-submit:active { opacity: 0.8; }
.memory-result {
  text-align: center; font-size: 26rpx; color: #a855f7;
  font-weight: 600; margin: 16rpx 0;
}

/* ===== SCHULTE (5x5) ===== */
.schulte-info {
  font-size: 24rpx; color: #86868B; margin-bottom: 16rpx; text-align: center;
}
.schulte-next-num { color: #5856D6; font-weight: 700; }
.schulte-grid {
  display: grid; gap: 10rpx; margin: 16rpx 0;
}
.schulte-5x5 { grid-template-columns: repeat(5, 1fr); }
.schulte-cell {
  aspect-ratio: 1;
  background: #F5F5F7; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 700; color: #1D1D1F;
  border: 2rpx solid rgba(0,0,0,0.06);
  transition: all 0.2s ease;
}
.schulte-cell:active { transform: scale(0.92); }
.cell-found {
  background: rgba(88,86,214,0.10); border-color: rgba(88,86,214,0.25);
  color: #5856D6;
}
.schulte-wrong {
  text-align: center; font-size: 24rpx; color: #ef4444; margin-top: 8rpx;
}
.schulte-result { text-align: center; padding: 16rpx 0; }
.schulte-time-big { font-size: 64rpx; font-weight: 900; color: #3b82f6; line-height: 1; }
.schulte-unit { font-size: 26rpx; color: #86868B; }

/* ===== MATH (timed) ===== */
.math-progress {
  font-size: 24rpx; color: #86868B; margin-bottom: 12rpx; text-align: center;
}
.math-timer {
  height: 6rpx; background: rgba(0,0,0,0.06); border-radius: 3rpx;
  overflow: hidden; margin-bottom: 16rpx;
}
.math-timer-fill {
  height: 100%; width: 100%;
  background: linear-gradient(90deg, #ef4444, #f59e0b, #5856D6);
  border-radius: 3rpx;
  transform-origin: left;
}
.math-timer-anim {
  animation: timerDrain 8s linear forwards;
}
@keyframes timerDrain {
  from { width: 100%; }
  to { width: 0%; }
}
.math-question {
  font-size: 52rpx; font-weight: 800; text-align: center;
  color: #1D1D1F; margin: 24rpx 0;
  animation: qPop 0.3s ease;
}
@keyframes qPop {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}
.math-options {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16rpx; margin-bottom: 16rpx;
}
.math-option {
  background: #F5F5F7; border: 2rpx solid rgba(0,0,0,0.06);
  border-radius: 20rpx; padding: 28rpx;
  text-align: center; font-size: 36rpx; font-weight: 700; color: #1D1D1F;
  transition: all 0.2s ease;
}
.math-option:active { transform: scale(0.95); }
.opt-correct {
  background: rgba(88,86,214,0.10) !important;
  border-color: #5856D6 !important;
  color: #5856D6 !important;
}
.opt-wrong {
  background: rgba(239,68,68,0.10) !important;
  border-color: #ef4444 !important;
  color: #ef4444 !important;
  animation: shakeX 0.4s ease;
}
.math-result {
  text-align: center; font-size: 28rpx; color: #ef4444;
  font-weight: 600; margin: 20rpx 0;
}

/* ===== STROOP ===== */
.stroop-progress {
  font-size: 24rpx; color: #86868B; margin-bottom: 8rpx; text-align: center;
}
.stroop-hint {
  font-size: 22rpx; color: #86868B; text-align: center; margin-bottom: 20rpx;
}
.stroop-hint-em { color: #ec4899; font-weight: 700; }
.stroop-display {
  font-size: 96rpx; font-weight: 900; text-align: center;
  margin: 32rpx 0; animation: qPop 0.3s ease;
  line-height: 1.2;
}
.stroop-options {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.stroop-option {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  background: #F5F5F7; border: 2rpx solid rgba(0,0,0,0.06);
  border-radius: 20rpx; padding: 24rpx;
  font-size: 30rpx; font-weight: 700; color: #1D1D1F;
  transition: all 0.2s ease;
}
.stroop-option:active { transform: scale(0.95); }
.stroop-color-dot {
  width: 28rpx; height: 28rpx; border-radius: 50%;
}
.stroop-result {
  text-align: center; font-size: 28rpx; color: #ec4899;
  font-weight: 600; margin: 20rpx 0;
}

/* ===== VISUAL SEARCH ===== */
.visual-progress {
  font-size: 24rpx; color: #86868B; margin-bottom: 8rpx; text-align: center;
}
.visual-hint {
  font-size: 24rpx; color: #5856D6; text-align: center;
  margin-bottom: 16rpx; font-weight: 600;
}
.visual-grid {
  display: grid; gap: 8rpx; margin: 8rpx 0;
}
.visual-cell {
  aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; background: #F5F5F7;
  border-radius: 12rpx; border: 2rpx solid rgba(0,0,0,0.06);
  transition: all 0.2s ease;
}
.visual-cell:active { transform: scale(0.9); }
.vis-correct {
  background: rgba(88,86,214,0.12) !important;
  border-color: #5856D6 !important;
  animation: optPop 0.3s ease;
}
.vis-wrong {
  background: rgba(239,68,68,0.12) !important;
  border-color: #ef4444 !important;
  animation: shakeX 0.4s ease;
}
@keyframes optPop {
  0% { transform: scale(0.95); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1); }
}
.visual-result {
  text-align: center; font-size: 28rpx; color: #5856D6;
  font-weight: 600; margin: 20rpx 0;
}

/* ===== SEQUENCE MEMORY ===== */
.seq-level {
  font-size: 24rpx; color: #86868B; margin-bottom: 20rpx; text-align: center;
}
.seq-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 12rpx; margin: 16rpx auto;
  max-width: 420rpx;
}
.seq-cell {
  aspect-ratio: 1;
  background: #F5F5F7; border-radius: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
  transition: all 0.2s ease;
}
.seq-cell:active { transform: scale(0.92); }
.seq-active {
  background: #f97316 !important;
  border-color: #f97316 !important;
  box-shadow: 0 0 24rpx rgba(249,115,22,0.35);
}
.seq-hit {
  background: rgba(88,86,214,0.20) !important;
  border-color: #5856D6 !important;
}
.seq-wrong {
  background: rgba(239,68,68,0.20) !important;
  border-color: #ef4444 !important;
  animation: shakeX 0.4s ease;
}
.seq-result { text-align: center; padding: 16rpx 0; }
.seq-max-level {
  font-size: 32rpx; font-weight: 700; color: #f97316; margin-bottom: 8rpx;
}

/* ===== NEXT / FINISH BUTTONS ===== */
.next-btn {
  display: block; text-align: center;
  background: rgba(88,86,214,0.10); color: #5856D6;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx; border-radius: 20rpx;
  margin-top: 20rpx;
}
.next-btn:active { opacity: 0.7; }
.finish-btn {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff;
  box-shadow: 0 6rpx 24rpx rgba(88,86,214,0.25);
}

/* ===== RESULT ===== */
.result { text-align: center; padding-top: 48rpx; }
.result-ring {
  width: 200rpx; height: 200rpx; margin: 0 auto 24rpx;
  border: 8rpx solid #5856D6; border-radius: 50%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  box-shadow: 0 0 40rpx rgba(88,86,214,0.18);
  animation: ringGlow 2s ease infinite;
}
@keyframes ringGlow {
  0%,100% { box-shadow: 0 0 40rpx rgba(88,86,214,0.15); }
  50% { box-shadow: 0 0 60rpx rgba(88,86,214,0.30); }
}
.ring-score {
  font-size: 64rpx; font-weight: 900; color: #5856D6; line-height: 1;
}
.ring-label { font-size: 22rpx; color: #86868B; font-weight: 600; }
.result-level {
  font-size: 36rpx; font-weight: 800; color: #1D1D1F; margin-bottom: 20rpx;
}

/* Cognitive age */
.cog-age-card {
  display: inline-flex; flex-direction: column;
  align-items: center; background: #FFFFFF;
  border: 1rpx solid rgba(168,85,247,0.15);
  border-radius: 24rpx; padding: 24rpx 48rpx; margin-bottom: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.cog-age-num {
  font-size: 72rpx; font-weight: 900; color: #a855f7; line-height: 1;
}
.cog-age-unit { font-size: 28rpx; color: #a855f7; }
.cog-age-title { font-size: 22rpx; color: #86868B; margin-top: 4rpx; }
.cog-age-label {
  font-size: 24rpx; color: #a855f7; font-weight: 600;
  background: rgba(168,85,247,0.08); padding: 4rpx 20rpx;
  border-radius: 12rpx; margin-top: 8rpx;
}

/* Radar chart */
.radar-wrap {
  display: flex; justify-content: center;
  margin-bottom: 24rpx;
}
.radar-canvas { width: 400rpx; height: 400rpx; }

/* Breakdown */
.result-breakdown {
  text-align: left; margin: 0 8rpx 24rpx;
}
.breakdown-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.bd-icon {
  width: 40rpx; height: 40rpx; border-radius: 10rpx;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.bd-info { flex: 1; }
.bd-name { font-size: 24rpx; color: #86868B; display: block; margin-bottom: 6rpx; }
.bd-bar-bg {
  height: 8rpx; background: rgba(0,0,0,0.06); border-radius: 4rpx;
  overflow: hidden;
}
.bd-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #5856D6, #AF52DE);
  border-radius: 4rpx;
  transition: width 1s ease;
}
.bd-score {
  font-size: 28rpx; font-weight: 700; color: #1D1D1F;
  min-width: 48rpx; text-align: right;
}

/* Friend comparison in result */
.compare-result {
  background: #FFFFFF; border: 1rpx solid rgba(59,130,246,0.12);
  border-radius: 20rpx; padding: 24rpx; margin-bottom: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.compare-vs {
  display: flex; align-items: center; justify-content: center; gap: 32rpx;
}
.compare-mine, .compare-friend { text-align: center; }
.compare-val { font-size: 44rpx; font-weight: 900; color: #1D1D1F; }
.compare-mine .compare-val { color: #5856D6; }
.compare-friend .compare-val { color: #3b82f6; }
.compare-tag { font-size: 22rpx; color: #86868B; }
.compare-vs-text { font-size: 28rpx; color: #86868B; font-weight: 700; }
.compare-verdict {
  font-size: 28rpx; font-weight: 700; color: #f59e0b; margin-top: 12rpx;
}

.streak-badge {
  display: inline-block;
  background: rgba(245,158,11,0.10); color: #f59e0b;
  font-size: 24rpx; font-weight: 600;
  padding: 8rpx 28rpx; border-radius: 20rpx;
  margin-bottom: 28rpx;
}

.result-actions {
  display: flex; gap: 24rpx;
  justify-content: center; align-items: center;
  margin-bottom: 20rpx;
}
.retry-btn {
  background: rgba(88,86,214,0.10); color: #5856D6;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx 48rpx; border-radius: 44rpx;
  line-height: 1.5;
}
.retry-btn:active { opacity: 0.7; }
.share-btn {
  background: linear-gradient(135deg, #5856D6, #AF52DE) !important;
  color: #fff !important; font-size: 28rpx; font-weight: 600;

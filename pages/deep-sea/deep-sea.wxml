<view class="page">
  <!-- Depth indicator -->
  <view class="depth-indicator">
    <view class="depth-value">{{currentDepth}}m</view>
    <view class="depth-label">深度</view>
  </view>

  <!-- Light overlay: gets darker as you scroll -->
  <view class="light-overlay" style="opacity: {{currentDepth > 200 ? (currentDepth / 11000 * 0.6) : 0}};"></view>

  <!-- Floating bubbles -->
  <view
    wx:for="{{bubbles}}"
    wx:key="id"
    class="bubble"
    style="left: {{item.x}}%; width: {{item.size}}rpx; height: {{item.size}}rpx; animation-duration: {{item.duration}}ms;"
  ></view>

  <!-- Ocean scroll -->
  <scroll-view
    scroll-y
    class="ocean"
    bindscroll="onScroll"
    scroll-top="{{scrollTop}}"
  >
    <!-- Surface start hint -->
    <view class="surface-hint">
      <view class="surface-text">向下滑动开始深海之旅</view>
      <view class="surface-arrow">↓</view>
    </view>

    <!-- Zones -->
    <view
      wx:for="{{zones}}"
      wx:key="name"
      class="zone"
      style="background: linear-gradient({{item.color1}}, {{item.color2}}); min-height: {{item.height}}rpx;"
    >
      <view class="zone-header">
        <view class="zone-name">{{item.name}}</view>
        <view class="zone-range">{{item.from}}m - {{item.to}}m</view>
      </view>

      <!-- Creatures with local images -->
      <view
        wx:for="{{item.creatures}}"
        wx:for-item="c"
        wx:key="name"
        class="creature creature-{{c.size}} swim-anim"
        style="margin-top: {{c.offset}}rpx;"
        bindtap="showCreatureBio"
        data-name="{{c.name}}"
        data-bio="{{c.bio}}"
        data-img="{{c.img}}"
        data-depth="{{c.depth}}"
      >
        <image class="creature-img creature-img-{{c.size}}" src="{{c.img}}" mode="aspectFill"></image>
        <view class="creature-info">
          <view class="creature-name">{{c.name}}</view>
          <view class="creature-depth">{{c.depth}}m</view>
          <view class="creature-tap-hint">点击查看详情</view>
        </view>
      </view>

      <!-- Landmarks -->
      <view
        wx:for="{{item.landmarks}}"
        wx:for-item="lm"
        wx:key="text"
        class="landmark"
        style="margin-top: {{lm.offset}}rpx;"
      >
        <view class="landmark-line"></view>
        <view class="landmark-text">{{lm.depth}}m - {{lm.text}}</view>
      </view>
    </view>

    <!-- Bottom -->
    <view class="bottom">
      <view class="bottom-text">你已到达地球最深处</view>
      <view class="bottom-sub">挑战者深渊 10,935m</view>
      <button class="share-btn" open-type="share">分享深海之旅</button>
    </view>
  </scroll-view>

  <!-- Creature bio modal -->
  <view class="bio-mask" wx:if="{{showBio}}" bindtap="closeBio">
    <view class="bio-card" catchtap="">
      <image class="bio-img" src="{{bioCreature.img}}" mode="aspectFill"></image>
      <view class="bio-name">{{bioCreature.name}}</view>
      <view class="bio-depth-tag">深度: {{bioCreature.depth}}m</view>
      <view class="bio-text">{{bioCreature.bio}}</view>
      <view class="bio-close" bindtap="closeBio">关闭</view>
    </view>
  </view>
</view>

.page {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* Light overlay for depth attenuation */
.light-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #000;
  pointer-events: none;
  z-index: 5;
  transition: opacity 0.5s ease;
}

/* Depth indicator */
.depth-indicator {
  position: fixed;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 20;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10px);
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(108, 99, 255, 0.3);
}

.depth-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #6c63ff;
  font-variant-numeric: tabular-nums;
}

.depth-label {
  font-size: 20rpx;
  color: #8888a0;
  margin-top: 4rpx;
}

/* Bubbles */
@keyframes bubble-rise {
  0% { transform: translateY(100vh); opacity: 0.6; }
  50% { opacity: 0.4; }
  100% { transform: translateY(-100rpx); opacity: 0; }
}

.bubble {
  position: fixed;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.05));
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  animation: bubble-rise linear forwards;
  pointer-events: none;
  z-index: 6;
}

/* Ocean scroll */
.ocean {
  height: 100vh;
}

/* Surface hint */
.surface-hint {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.surface-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
}

@keyframes arrow-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(16rpx); }
}

.surface-arrow {
  font-size: 48rpx;
  margin-top: 16rpx;
  animation: arrow-bounce 1.5s ease-in-out infinite;
  color: rgba(255, 255, 255, 0.5);
}

/* Zone */
.zone {
  padding: 48rpx 32rpx;
  position: relative;
}

.zone-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.zone-name {
  font-size: 40rpx;
  font-weight: 700;
  opacity: 0.7;
}

.zone-range {
  font-size: 24rpx;
  opacity: 0.4;
}

/* Creature swim animation */
@keyframes swim {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(12rpx) rotate(1deg); }
  75% { transform: translateX(-12rpx) rotate(-1deg); }
}

.swim-anim {
  /* applied via creature-visible which chains appear + swim */
}

/* Creature reveal on scroll */
.creature-hidden {
  opacity: 0;
  transform: translateX(-40rpx);
  pointer-events: none;
}

@keyframes creature-appear {
  from { opacity: 0; transform: translateX(-40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.creature-visible {
  opacity: 1;
  transform: translateX(0);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}

/* Creatures with local images */
.creature {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(8px);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: transform 0.2s ease;
}

.creature:active {
  transform: scale(0.97);
}

.creature-img {
  border-radius: 16rpx;
  flex-shrink: 0;
}

.creature-img-small {
  width: 100rpx;
  height: 100rpx;
}

.creature-img-medium {
  width: 130rpx;
  height: 130rpx;
}

.creature-img-large {
  width: 160rpx;
  height: 120rpx;
}

.creature-info {
  flex: 1;
  margin-left: 20rpx;
}

.creature-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.creature-depth {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.creature-tap-hint {
  font-size: 20rpx;
  color: rgba(108, 99, 255, 0.7);
  margin-top: 6rpx;
}

/* Landmark reveal */
.landmark-hidden {
  opacity: 0;
  transform: translateX(-30rpx);
}

.landmark-visible {
  opacity: 1;
  transform: translateX(0);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

/* Landmarks */
.landmark {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.landmark-line {
  width: 60rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.landmark-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-style: italic;
}

/* Bottom */
.bottom {
  background: #020204;
  padding: 80rpx 32rpx;
  text-align: center;
}

.bottom-text {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.bottom-sub {
  font-size: 28rpx;
  color: #8888a0;
}

/* Bio modal */
.bio-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 100;
  display: flex;
  justify-content: center;
  align-items: center;
  animation: fade-in 0.2s ease;
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.bio-card {
  width: 80%;
  max-width: 600rpx;
  background: #14141f;
  border-radius: 32rpx;
  padding: 0;
  overflow: hidden;
  animation: slide-up 0.3s ease-out;
  border: 1rpx solid rgba(108, 99, 255, 0.2);
}

.bio-img {
  width: 100%;
  height: 280rpx;
}

.bio-name {
  font-size: 40rpx;
  font-weight: 700;
  padding: 24rpx 32rpx 0;
}

.bio-depth-tag {
  display: inline-block;
  margin: 8rpx 32rpx 0;
  padding: 6rpx 20rpx;
  background: rgba(108, 99, 255, 0.15);
  color: #6c63ff;
  font-size: 22rpx;
  border-radius: 16rpx;
}

.bio-text {
  font-size: 28rpx;
  color: #aaa;
  line-height: 1.7;
  padding: 16rpx 32rpx 24rpx;
}

.bio-close {
  text-align: center;
  padding: 20rpx;
  color: #6c63ff;
  font-size: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.share-btn {
  margin-top: 32rpx;
  background: rgba(108, 99, 255, 0.15);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.3);
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.share-btn::after { border: none; }

/* 关注智变纪 */
.follow-hint {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: #8888a0;
  opacity: 0.8;
}

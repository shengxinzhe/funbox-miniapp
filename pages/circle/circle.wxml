<view class="page {{fadeIn ? 'fade-in' : ''}}">

  <!-- INTRO -->
  <block wx:if="{{phase === 'intro'}}">
    <view class="intro">
      <view class="intro-circle-wrap">
        <view class="intro-circle"></view>
      </view>
      <view class="intro-title">画个完美圆</view>
      <view class="intro-desc">用手指画一个圆，AI 评估圆度 0-100%</view>
      <view class="intro-tips">
        <view class="tip">一笔画完，首尾相连</view>
        <view class="tip">越圆分数越高</view>
      </view>
      <view wx:if="{{bestScore > 0}}" class="best-badge">
        最佳: {{bestScore}}%
      </view>
      <view class="start-btn" bindtap="startDraw">开始画圆</view>
    </view>
  </block>

  <!-- CANVAS (always in DOM, shown during drawing and result) -->
  <block wx:if="{{phase === 'drawing' || phase === 'result'}}">
    <view class="draw-phase">
      <view wx:if="{{phase === 'drawing'}}" class="draw-hint {{drawing ? 'hint-hide' : ''}}">用手指画一个圆</view>

      <view class="canvas-wrap" style="width:{{canvasSize}}px;height:{{canvasSize}}px;">
        <canvas
          canvas-id="circleCanvas"
          style="width:{{canvasSize}}px;height:{{canvasSize}}px;"
          bindtouchstart="onTouchStart"
          bindtouchmove="onTouchMove"
          bindtouchend="onTouchEnd"
        ></canvas>
        <view wx:if="{{showFit}}" class="fit-label">— 虚线为完美圆 —</view>
      </view>

      <view wx:if="{{phase === 'drawing'}}" class="draw-sub">松手即评分</view>

      <!-- Result content below canvas -->
      <block wx:if="{{phase === 'result'}}">
        <view class="score-area {{scoreAnim ? 'score-pop' : ''}}">
          <view class="score-num">{{score}}<text class="score-pct">%</text></view>
          <view class="score-rank">{{rank}}</view>
        </view>

        <view wx:if="{{score === bestScore && attempts > 0}}" class="new-best">新纪录!</view>

        <view class="result-meta">
          <text>第 {{attempts}} 次尝试</text>
          <text wx:if="{{bestScore > 0}}"> · 最佳 {{bestScore}}%</text>
        </view>

        <view class="result-actions">
          <view class="retry-btn" bindtap="retry">再画一次</view>
          <button class="share-btn" open-type="share">分享成绩</button>
        </view>
      </block>
    </view>
  </block>

</view>

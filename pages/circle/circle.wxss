.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 32rpx 60rpx;
  opacity: 0; transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* INTRO */
.intro { text-align: center; padding-top: 60rpx; }
.intro-circle-wrap {
  width: 160rpx; height: 160rpx; margin: 0 auto 32rpx;
  position: relative;
}
.intro-circle {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid #5856D6;
  position: absolute; top: 20rpx; left: 20rpx;
  animation: introSpin 4s linear infinite;
  box-shadow: 0 0 30rpx rgba(88,86,214,0.2);
}
@keyframes introSpin {
  0% { transform: rotate(0deg) scale(1); box-shadow: 0 0 30rpx rgba(88,86,214,0.2); }
  50% { transform: rotate(180deg) scale(1.05); box-shadow: 0 0 50rpx rgba(88,86,214,0.35); }
  100% { transform: rotate(360deg) scale(1); box-shadow: 0 0 30rpx rgba(88,86,214,0.2); }
}
.intro-title {
  font-size: 52rpx; font-weight: 800; color: #1D1D1F; margin-bottom: 8rpx;
}
.intro-desc {
  font-size: 26rpx; color: #86868B; margin-bottom: 32rpx;
}
.intro-tips {
  display: flex; justify-content: center; gap: 24rpx;
  margin-bottom: 28rpx;
}
.tip {
  background: rgba(88,86,214,0.08); color: #5856D6;
  font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 16rpx;
}
.best-badge {
  display: inline-block;
  background: rgba(245,158,11,0.1); color: #d97706;
  font-size: 26rpx; font-weight: 700;
  padding: 10rpx 32rpx; border-radius: 20rpx;
  margin-bottom: 28rpx;
}
.start-btn {
  display: inline-block;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff; font-size: 32rpx; font-weight: 600;
  padding: 28rpx 100rpx; border-radius: 52rpx;
  box-shadow: 0 8rpx 32rpx rgba(88,86,214,0.28);
  margin-bottom: 24rpx;
}
.start-btn:active { transform: scale(0.96); opacity: 0.9; }
.back-link { font-size: 26rpx; color: #86868B; margin-top: 16rpx; }

/* DRAWING */
.draw-phase { text-align: center; padding-top: 32rpx; }
.draw-hint {
  font-size: 28rpx; color: #86868B; margin-bottom: 20rpx;
  transition: opacity 0.3s ease;
}
.hint-hide { opacity: 0.3; }
.canvas-wrap {
  margin: 0 auto;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  overflow: hidden;
  position: relative;
}
.draw-sub {
  font-size: 22rpx; color: #86868B; margin-top: 16rpx;
}

/* RESULT */
.result { text-align: center; padding-top: 20rpx; }
.result-canvas { margin-bottom: 20rpx; }
.fit-label {
  position: absolute; bottom: 12rpx; left: 0; right: 0;
  text-align: center; font-size: 20rpx; color: #86868B;
  animation: fitFade 0.6s ease;
}
@keyframes fitFade {
  from { opacity: 0; } to { opacity: 1; }
}

.score-area {
  opacity: 0; transform: scale(0.7);
}
.score-pop {
  animation: scorePop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes scorePop {
  from { opacity: 0; transform: scale(0.7); }
  to { opacity: 1; transform: scale(1); }
}
.score-num {
  font-size: 96rpx; font-weight: 900; color: #5856D6;
  line-height: 1;
}
.score-pct { font-size: 40rpx; font-weight: 600; }
.score-rank {
  font-size: 32rpx; font-weight: 700; color: #1D1D1F;
  margin-top: 4rpx; margin-bottom: 12rpx;
}
.new-best {
  display: inline-block;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #fff; font-size: 24rpx; font-weight: 700;
  padding: 6rpx 24rpx; border-radius: 16rpx;
  margin-bottom: 12rpx;
  animation: bestPulse 1s ease infinite;
}
@keyframes bestPulse {
  0%,100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
.result-meta {
  font-size: 24rpx; color: #86868B; margin-bottom: 24rpx;
}
.result-actions {
  display: flex; gap: 24rpx;
  justify-content: center; align-items: center;
  margin-bottom: 16rpx;
}
.retry-btn {
  background: rgba(88,86,214,0.1); color: #5856D6;
  font-size: 28rpx; font-weight: 600;
  padding: 24rpx 48rpx; border-radius: 44rpx;
  line-height: 1.5;
}
.retry-btn:active { opacity: 0.7; }
.share-btn {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff !important; font-size: 28rpx; font-weight: 600;
  padding: 24rpx 48rpx; border-radius: 44rpx;
  line-height: 1.5; border: none;
  margin: 0; min-height: 0;
}
.share-btn::after { border: none; }
.share-btn:active { opacity: 0.9; }

/* bead-art.wxss — Apple Light Theme */

.page {
  min-height: 100vh;
  background: #F5F5F7;
}

/* ── INTRO ── */
.intro {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx 40rpx;
}

.intro-hero { width: 300rpx; height: 300rpx; margin-bottom: 28rpx; }
.intro-canvas { width: 300rpx; height: 300rpx; }

.intro-title { font-size: 52rpx; font-weight: 700; color: #1D1D1F; letter-spacing: 2rpx; }
.intro-subtitle { font-size: 28rpx; color: #86868B; margin-top: 6rpx; }
.intro-desc { font-size: 26rpx; color: #AEAEB2; margin-top: 12rpx; text-align: center; line-height: 1.6; }

.stats-row { display: flex; gap: 20rpx; margin-top: 32rpx; }
.stat-card {
  background: #FFFFFF; border-radius: 24rpx; padding: 20rpx 36rpx;
  text-align: center; box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.stat-val { font-size: 36rpx; font-weight: 700; color: #5856D6; }
.stat-label { font-size: 22rpx; color: #86868B; margin-top: 4rpx; }

.mode-section { width: 100%; margin-top: 40rpx; }
.mode-title { font-size: 30rpx; font-weight: 600; color: #1D1D1F; margin-bottom: 20rpx; text-align: center; }
.mode-cards { display: flex; gap: 20rpx; }
.mode-card {
  flex: 1; background: #FFFFFF; border-radius: 24rpx; padding: 32rpx 16rpx;
  text-align: center; box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.mode-card:active { background: #F2F2F7; }
.mode-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.mode-name { font-size: 30rpx; font-weight: 600; color: #1D1D1F; }
.mode-desc { font-size: 22rpx; color: #86868B; margin-top: 6rpx; }

/* ── LEVEL SELECT ── */
.level-select { padding: 16rpx 24rpx; }

.section-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.back-btn { font-size: 28rpx; color: #5856D6; font-weight: 500; }
.back-btn:active { opacity: 0.6; }
.section-title { font-size: 34rpx; font-weight: 700; color: #1D1D1F; }

.level-tabs { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.tab {
  padding: 10rpx 28rpx; border-radius: 20rpx; font-size: 26rpx;
  background: #FFFFFF; color: #86868B; font-weight: 500;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}
.tab.active {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF;
}

.level-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.level-card {
  background: #FFFFFF; border-radius: 20rpx; padding: 16rpx;
  text-align: center; box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  position: relative;
}
.level-card:active { background: #F2F2F7; }
.level-preview { width: 100%; height: 160rpx; border-radius: 12rpx; }
.level-name { font-size: 24rpx; font-weight: 600; color: #1D1D1F; margin-top: 8rpx; }
.level-size { font-size: 20rpx; color: #AEAEB2; }
.level-score {
  position: absolute; top: 8rpx; right: 8rpx;
  background: #5856D6; color: #FFF; font-size: 20rpx; font-weight: 600;
  padding: 4rpx 12rpx; border-radius: 10rpx;
}

/* ── PLAYING ── */
.play-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 24rpx; background: #FFFFFF;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}
.play-info { }
.info-text { font-size: 28rpx; font-weight: 600; color: #5856D6; }
.play-actions { display: flex; gap: 12rpx; }
.action-btn {
  padding: 8rpx 20rpx; background: #F2F2F7; border-radius: 14rpx;
  font-size: 24rpx; color: #5856D6; font-weight: 500;
}
.action-btn:active { background: #E5E5EA; }

/* Reference bar */
.ref-bar { padding: 12rpx 24rpx; display: flex; align-items: center; gap: 16rpx; }
.ref-toggle {
  padding: 8rpx 20rpx; background: #FFFFFF; border-radius: 14rpx;
  font-size: 24rpx; color: #5856D6; font-weight: 500;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}
.ref-toggle.active { background: #5856D6; color: #FFFFFF; }
.ref-preview { }
.ref-canvas { width: 120rpx; height: 120rpx; border-radius: 12rpx; }

/* Board */
.board-container {
  width: 100%; padding: 8rpx 12rpx;
  display: flex; justify-content: center;
}
.board-canvas {
  width: 710rpx; height: 710rpx;
  background: #FFFFFF; border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* Palette */
.palette-section {
  padding: 12rpx 24rpx;
}
.palette-row {
  display: flex; flex-wrap: wrap; gap: 10rpx; justify-content: center;
  padding: 12rpx 0;
}
.color-dot {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.12);
  border: 4rpx solid transparent;
  transition: transform 0.15s;
}
.color-dot.selected {
  border-color: #1D1D1F;
  transform: scale(1.2);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.2);
}

.tool-row { display: flex; gap: 12rpx; justify-content: center; margin-top: 8rpx; }
.tool-btn {
  padding: 8rpx 28rpx; background: #FFFFFF; border-radius: 16rpx;
  font-size: 24rpx; color: #86868B; font-weight: 500;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}
.tool-btn.active {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF;
}

/* Done */
.done-bar { padding: 12rpx 24rpx 24rpx; }
.done-btn {
  width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  border-radius: 44rpx; color: #FFFFFF; font-size: 32rpx; font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(88,86,214,0.25);
}
.done-btn:active { opacity: 0.85; }

/* ── RESULT ── */
.result {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; padding: 40rpx;
}
.result-card {
  background: #FFFFFF; border-radius: 32rpx; padding: 40rpx 32rpx;
  text-align: center; width: 100%; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.result-title { font-size: 40rpx; font-weight: 700; color: #1D1D1F; margin-bottom: 24rpx; }
.result-canvas-wrap { display: flex; justify-content: center; margin-bottom: 24rpx; }
.result-canvas { width: 400rpx; height: 400rpx; border-radius: 16rpx; }
.result-score { margin-bottom: 8rpx; }
.score-num { font-size: 64rpx; font-weight: 800; color: #5856D6; }
.score-label { font-size: 26rpx; color: #86868B; margin-left: 8rpx; }
.result-stars { margin-bottom: 24rpx; }
.star { font-size: 48rpx; color: #E5E5EA; margin: 0 6rpx; }
.star.lit { color: #FF9F0A; }
.result-btns { display: flex; gap: 16rpx; margin-top: 16rpx; }
.result-btn {
  flex: 1; height: 84rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 42rpx; font-size: 28rpx; font-weight: 600;
}
.result-btn.primary {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF; box-shadow: 0 6rpx 20rpx rgba(88,86,214,0.25);
}
.result-btn.secondary { background: #F2F2F7; color: #5856D6; }
.result-btn:active { opacity: 0.85; }

/* ── IRON OVERLAY ── */
.iron-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center;
  z-index: 300;
}
.iron-content {
  background: #FFFFFF; border-radius: 32rpx; padding: 48rpx 64rpx;
  text-align: center; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}
.iron-icon { font-size: 80rpx; animation: ironPulse 0.6s ease-in-out infinite alternate; }
.iron-text { font-size: 30rpx; font-weight: 600; color: #1D1D1F; margin-top: 16rpx; }

@keyframes ironPulse {
  from { transform: scale(1); }
  to { transform: scale(1.15); }
}

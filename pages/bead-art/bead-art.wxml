<!--bead-art.wxml-->
<view class="page">

  <!-- INTRO -->
  <view class="intro" wx:if="{{phase === 'intro'}}">
    <view class="intro-hero">
      <canvas type="2d" id="intro-canvas" class="intro-canvas"></canvas>
    </view>
    <view class="intro-title">拼豆大师</view>
    <view class="intro-subtitle">像素拼豆创作</view>
    <view class="intro-desc">照图拼豆或自由创作，完成后熨烫成型</view>

    <view class="stats-row" wx:if="{{completedCount > 0}}">
      <view class="stat-card">
        <view class="stat-val">{{completedCount}}</view>
        <view class="stat-label">已完成</view>
      </view>
      <view class="stat-card">
        <view class="stat-val">{{bestScore}}%</view>
        <view class="stat-label">最高准确率</view>
      </view>
    </view>

    <view class="mode-section">
      <view class="mode-title">选择模式</view>
      <view class="mode-cards">
        <view class="mode-card" bindtap="enterPuzzle">
          <view class="mode-icon">🧩</view>
          <view class="mode-name">照图拼</view>
          <view class="mode-desc">还原参考图案</view>
        </view>
        <view class="mode-card" bindtap="enterFree">
          <view class="mode-icon">🎨</view>
          <view class="mode-name">自由创作</view>
          <view class="mode-desc">随心所欲拼图</view>
        </view>
      </view>
    </view>
  </view>

  <!-- LEVEL SELECT -->
  <view class="level-select" wx:if="{{phase === 'levelSelect'}}">
    <view class="section-header">
      <view class="back-btn" bindtap="goIntro">← 返回</view>
      <view class="section-title">选择图案</view>
    </view>
    <view class="level-tabs">
      <view class="tab {{difficulty === 'easy' ? 'active' : ''}}" bindtap="setDifficulty" data-d="easy">初级</view>
      <view class="tab {{difficulty === 'medium' ? 'active' : ''}}" bindtap="setDifficulty" data-d="medium">中级</view>
      <view class="tab {{difficulty === 'hard' ? 'active' : ''}}" bindtap="setDifficulty" data-d="hard">高级</view>
    </view>
    <view class="level-grid">
      <view class="level-card" wx:for="{{filteredLevels}}" wx:key="id"
        bindtap="selectLevel" data-id="{{item.id}}">
        <canvas type="2d" id="preview-{{item.id}}" class="level-preview"></canvas>
        <view class="level-name">{{item.name}}</view>
        <view class="level-size">{{item.size}}x{{item.size}}</view>
        <view class="level-score" wx:if="{{item.score > 0}}">{{item.score}}%</view>
      </view>
    </view>
  </view>

  <!-- PLAYING -->
  <block wx:if="{{phase === 'playing'}}">
    <view class="play-header">
      <view class="back-btn" bindtap="confirmExit">← 退出</view>
      <view class="play-info" wx:if="{{mode === 'puzzle'}}">
        <text class="info-text">{{placedCount}}/{{totalCells}}</text>
      </view>
      <view class="play-info" wx:if="{{mode === 'free'}}">
        <text class="info-text">{{gridSize}}x{{gridSize}}</text>
      </view>
      <view class="play-actions">
        <view class="action-btn" bindtap="clearBoard">清空</view>
        <view class="action-btn" bindtap="undoLast">撤销</view>
      </view>
    </view>

    <!-- Reference image (puzzle mode) -->
    <view class="ref-bar" wx:if="{{mode === 'puzzle'}}">
      <view class="ref-toggle {{showRef ? 'active' : ''}}" bindtap="toggleRef">
        {{showRef ? '隐藏参考' : '显示参考'}}
      </view>
      <view class="ref-preview" wx:if="{{showRef}}">
        <canvas type="2d" id="ref-canvas" class="ref-canvas"></canvas>
      </view>
    </view>

    <!-- Board -->
    <view class="board-container">
      <canvas type="2d" id="board-canvas" class="board-canvas"
        bindtouchstart="onBoardTouch"
        bindtouchmove="onBoardMove"
        bindtouchend="onBoardTouchEnd"></canvas>
    </view>

    <!-- Color Palette -->
    <view class="palette-section">
      <view class="palette-row">
        <view class="color-dot {{selectedColor === idx ? 'selected' : ''}}"
          wx:for="{{palette}}" wx:key="index" wx:for-index="idx"
          style="background: {{item}}"
          bindtap="pickColor" data-idx="{{idx}}">
        </view>
      </view>
      <view class="tool-row">
        <view class="tool-btn {{tool === 'paint' ? 'active' : ''}}" bindtap="setTool" data-t="paint">画笔</view>
        <view class="tool-btn {{tool === 'erase' ? 'active' : ''}}" bindtap="setTool" data-t="erase">橡皮</view>
        <view class="tool-btn {{tool === 'fill' ? 'active' : ''}}" bindtap="setTool" data-t="fill">填充</view>
      </view>
    </view>

    <!-- Done button -->
    <view class="done-bar">
      <view class="done-btn" bindtap="finishWork" wx:if="{{mode === 'puzzle'}}">完成拼图</view>
      <view class="done-btn" bindtap="finishWork" wx:if="{{mode === 'free'}}">熨烫成型</view>
    </view>
  </block>

  <!-- RESULT -->
  <view class="result" wx:if="{{phase === 'result'}}">
    <view class="result-card">
      <view class="result-title" wx:if="{{mode === 'puzzle'}}">拼图完成!</view>
      <view class="result-title" wx:if="{{mode === 'free'}}">作品完成!</view>
      <view class="result-canvas-wrap">
        <canvas type="2d" id="result-canvas" class="result-canvas"></canvas>
      </view>
      <view class="result-score" wx:if="{{mode === 'puzzle'}}">
        <text class="score-num">{{score}}%</text>
        <text class="score-label">准确率</text>
      </view>
      <view class="result-stars" wx:if="{{mode === 'puzzle'}}">
        <text class="star {{score >= 30 ? 'lit' : ''}}">★</text>
        <text class="star {{score >= 70 ? 'lit' : ''}}">★</text>
        <text class="star {{score >= 95 ? 'lit' : ''}}">★</text>
      </view>
      <view class="result-btns">
        <view class="result-btn secondary" bindtap="goIntro">返回首页</view>
        <view class="result-btn primary" bindtap="retryOrNext" wx:if="{{mode === 'puzzle'}}">
          {{score >= 95 ? '下一关' : '重新挑战'}}
        </view>
        <view class="result-btn primary" bindtap="enterFree" wx:if="{{mode === 'free'}}">继续创作</view>
      </view>
    </view>
  </view>

  <!-- Iron Animation Overlay -->
  <view class="iron-overlay" wx:if="{{showIronAnim}}">
    <view class="iron-content">
      <view class="iron-icon">🔥</view>
      <view class="iron-text">熨烫中...</view>
    </view>
  </view>

</view>

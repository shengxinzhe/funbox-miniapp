/* cat-fishing.wxss — Apple Light Theme */

.page {
  min-height: 100vh;
  background: #F5F5F7;
  overflow: hidden;
}

/* ── INTRO ── */
.intro {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.intro-hero {
  width: 360rpx;
  height: 360rpx;
  margin-bottom: 32rpx;
}

.intro-canvas {
  width: 360rpx;
  height: 360rpx;
}

.intro-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: 2rpx;
}

.intro-subtitle {
  font-size: 28rpx;
  color: #86868B;
  margin-top: 8rpx;
}

.intro-desc {
  font-size: 26rpx;
  color: #AEAEB2;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.6;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  width: 100%;
  justify-content: center;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  text-align: center;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  flex: 1;
  max-width: 200rpx;
}

.stat-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #5856D6;
}

.stat-label {
  font-size: 22rpx;
  color: #86868B;
  margin-top: 4rpx;
}

.start-btn {
  margin-top: 48rpx;
  width: 420rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  border-radius: 48rpx;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(88,86,214,0.3);
}

.start-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* ── HUD ── */
.hud {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}

.hud-coins {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.coin-icon {
  color: #FF9F0A;
  font-size: 28rpx;
}

.coin-icon.small {
  font-size: 22rpx;
}

.coin-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #1D1D1F;
}

.hud-caught {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.caught-label {
  font-size: 24rpx;
  color: #86868B;
}

.caught-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #5856D6;
}

.hud-btns {
  display: flex;
  gap: 12rpx;
}

.hud-btn {
  padding: 8rpx 20rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #5856D6;
  font-weight: 500;
}

.hud-btn:active {
  background: #E5E5EA;
}

.hud-btn.afk-active {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF;
}

/* ── CANVAS AREA ── */
.canvas-area {
  width: 100%;
  height: 0;
  padding-bottom: 75%;
  position: relative;
  background: #FFFFFF;
}

.fish-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ── CONTROLS ── */
.controls {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 20rpx;
}

.bait-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  flex-shrink: 0;
}

.bait-display:active {
  background: #F2F2F7;
}

.bait-icon {
  font-size: 36rpx;
}

.bait-name {
  font-size: 26rpx;
  color: #1D1D1F;
  font-weight: 500;
}

.bait-arrow {
  font-size: 20rpx;
  color: #86868B;
  margin-left: 4rpx;
}

.cast-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  border-radius: 44rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(88,86,214,0.25);
}

.cast-btn:active {
  opacity: 0.85;
}

.cast-btn.disabled {
  background: linear-gradient(135deg, #C7C7CC, #AEAEB2);
  box-shadow: none;
}

/* ── TOAST ── */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  background: rgba(29,29,31,0.85);
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0;
  transition: all 0.3s ease;
  pointer-events: none;
  z-index: 100;
  white-space: nowrap;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

/* ── OVERLAY ── */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 200;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1D1D1F;
  text-align: center;
  margin-bottom: 24rpx;
}

.panel-close {
  text-align: center;
  color: #5856D6;
  font-size: 30rpx;
  font-weight: 500;
  padding: 20rpx;
  margin-top: 8rpx;
}

.panel-close:active {
  opacity: 0.6;
}

/* ── BAIT PANEL ── */
.bait-panel {
  width: 100%;
  background: #F5F5F7;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 70vh;
  overflow-y: auto;
}

.bait-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bait-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  gap: 16rpx;
}

.bait-item:active {
  background: #F2F2F7;
}

.bait-item.selected {
  border: 3rpx solid #5856D6;
}

.bait-item.locked {
  opacity: 0.5;
}

.bait-item-icon {
  font-size: 48rpx;
  width: 64rpx;
  text-align: center;
  flex-shrink: 0;
}

.bait-item-info {
  flex: 1;
  min-width: 0;
}

.bait-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.bait-item-desc {
  font-size: 22rpx;
  color: #86868B;
  margin-top: 4rpx;
}

.bait-item-cost {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF9F0A;
  flex-shrink: 0;
}

.bait-item-lock {
  font-size: 22rpx;
  color: #AEAEB2;
  flex-shrink: 0;
}

/* ── ALBUM PANEL ── */
.album-panel {
  width: 100%;
  background: #F5F5F7;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.album-progress {
  margin-bottom: 24rpx;
}

.album-bar {
  height: 12rpx;
  background: #E5E5EA;
  border-radius: 6rpx;
  overflow: hidden;
}

.album-fill {
  height: 100%;
  background: linear-gradient(90deg, #5856D6, #AF52DE);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.album-text {
  font-size: 24rpx;
  color: #86868B;
  display: block;
  text-align: center;
  margin-top: 8rpx;
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.album-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
  text-align: center;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  position: relative;
}

.album-item.unknown {
  opacity: 0.45;
}

.album-item.rarity-common {
  border-bottom: 4rpx solid #86868B;
}

.album-item.rarity-uncommon {
  border-bottom: 4rpx solid #34C759;
}

.album-item.rarity-rare {
  border-bottom: 4rpx solid #5856D6;
}

.album-item.rarity-legendary {
  border-bottom: 4rpx solid #FF9F0A;
}

.album-emoji {
  font-size: 48rpx;
  line-height: 1.2;
}

.album-name {
  font-size: 22rpx;
  color: #1D1D1F;
  font-weight: 500;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.album-count {
  font-size: 20rpx;
  color: #5856D6;
  font-weight: 600;
}

.album-rarity {
  font-size: 18rpx;
  color: #AEAEB2;
  margin-top: 2rpx;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  text-align: center;
  transition: background 0.5s ease;
  position: relative;
  overflow: hidden;
}

/* State backgrounds with smooth transitions */
.idle { background: #E8E8ED; }
.waiting { background: #FFE5E5; }
.ready { background: #E5F9ED; }
.early { background: #FFF3E0; }
.result { background: #F5F5F7; }

/* Ripple effect */
.ripple {
  position: fixed;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.12);
  transform: translate(-50%, -50%) scale(0);
  animation: ripple-expand 0.6s ease-out forwards;
  pointer-events: none;
  z-index: 100;
}

@keyframes ripple-expand {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0.6; }
  100% { transform: translate(-50%, -50%) scale(30); opacity: 0; }
}

/* Icon */
.icon {
  font-size: 140rpx;
  margin-bottom: 32rpx;
}

/* Animations */
@keyframes bounce-in {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.bounce-in {
  animation: bounce-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fade-in 0.4s ease-out;
}

.fade-in-delay {
  animation: fade-in 0.4s ease-out 0.15s both;
}

.fade-in-delay2 {
  animation: fade-in 0.4s ease-out 0.3s both;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.pulse {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes scale-up {
  from { transform: scale(0.5); }
  to { transform: scale(1); }
}

.scale-up {
  animation: scale-up 0.15s ease-out;
}

@keyframes flash {
  0%, 50% { opacity: 1; }
  25%, 75% { opacity: 0.5; }
}

.flash {
  animation: flash 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-16rpx); }
  40% { transform: translateX(16rpx); }
  60% { transform: translateX(-10rpx); }
  80% { transform: translateX(10rpx); }
}

.shake {
  animation: shake 0.4s ease;
}

/* Result card pop-in */
@keyframes pop-in {
  0% { transform: scale(0.3) translateY(100rpx); opacity: 0; }
  60% { transform: scale(1.05) translateY(-10rpx); opacity: 1; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 56rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.result-card.pop-in {
  animation: pop-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}

/* State-specific title colors */
.waiting .title { color: #D93025; }
.ready .title { color: #1A7F3C; }
.early .title { color: #B35900; }

.hint {
  font-size: 28rpx;
  color: #86868B;
  margin-bottom: 24rpx;
}

/* State-specific hint colors */
.waiting .hint { color: #C0392B; }
.ready .hint { color: #1A7F3C; }

.time {
  font-size: 120rpx;
  font-weight: 800;
  color: #5856D6;
  margin-bottom: 8rpx;
  font-variant-numeric: tabular-nums;
}

.rating {
  font-size: 30rpx;
  color: #86868B;
  margin-bottom: 16rpx;
}

.pill {
  display: inline-block;
  font-size: 26rpx;
  color: #5856D6;
  margin-top: 16rpx;
  padding: 12rpx 32rpx;
  background: rgba(88, 86, 214, 0.08);
  border-radius: 24rpx;
}

.share-btn {
  margin-top: 24rpx;
  background: rgba(88, 86, 214, 0.08);
  color: #5856D6;
  border: 1rpx solid rgba(88, 86, 214, 0.2);
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.share-btn::after {
  border: none;
}

/* Waiting state ring animation */
.waiting-ring {
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(217, 48, 37, 0.15);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: -180rpx;
  position: relative; z-index: 0;
}
.waiting-ring-inner {
  position: absolute; top: -6rpx; left: -6rpx; right: -6rpx; bottom: -6rpx;
  border-radius: 50%;
  border: 6rpx solid transparent;
  border-top-color: #D93025;
  animation: waitSpin 1.2s linear infinite;
}
@keyframes waitSpin {
  to { transform: rotate(360deg); }
}

/* 关注智变纪 */
.follow-hint {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: #86868B;
  opacity: 0.8;
}

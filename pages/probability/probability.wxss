/* ===== BASE ===== */
page {
  background: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #1D1D1F;
}

.page {
  min-height: 100vh;
  background: #F5F5F7;
  padding-bottom: 60rpx;
}

.phase {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== SHARED CARD ===== */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
}

/* ===== BUTTONS ===== */
.btn-primary {
  width: 100%;
  max-width: 600rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #30D158, #00C7BE);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(48, 209, 88, 0.35);
  margin-top: 32rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  width: 100%;
  max-width: 600rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: #FFFFFF;
  color: #30D158;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-top: 20rpx;
}

.btn-secondary::after {
  border: none;
}

/* ===== HOME PHASE ===== */
.home-phase {
  padding-top: 80rpx;
}

.home-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.hero-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.hero-title {
  font-size: 60rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #86868B;
  letter-spacing: 4rpx;
}

.home-desc-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 32rpx 36rpx;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.home-desc-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.home-desc-item + .home-desc-item {
  border-top: 1rpx solid #F2F2F7;
}

.desc-icon {
  font-size: 40rpx;
  width: 60rpx;
  text-align: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.desc-text {
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.5;
}

.best-score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.best-label {
  font-size: 26rpx;
  color: #86868B;
}

.best-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #30D158;
  font-family: -apple-system, "SF Mono", monospace;
}

/* ===== QUESTION PHASE ===== */
.question-phase {
  padding-top: 32rpx;
}

.round-indicator {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.round-dots {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.round-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E5E5EA;
  transition: all 0.3s;
}

.round-dot.done {
  background: #30D158;
}

.round-dot.active {
  background: #1D1D1F;
  transform: scale(1.3);
}

.round-text {
  font-size: 26rpx;
  color: #86868B;
  font-weight: 500;
}

.scenario-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 32rpx;
}

.scenario-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.scenario-question {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.scenario-cat-badge {
  font-size: 22rpx;
  color: #86868B;
  background: #F2F2F7;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  letter-spacing: 1rpx;
}

/* Estimate section */
.estimate-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 8rpx;
}

.estimate-label {
  font-size: 26rpx;
  color: #86868B;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.estimate-value {
  font-size: 100rpx;
  font-weight: 700;
  color: #1D1D1F;
  font-family: -apple-system, "SF Mono", monospace;
  line-height: 1.1;
  margin-bottom: 24rpx;
}

.estimate-pct {
  font-size: 48rpx;
  font-weight: 500;
  color: #86868B;
}

.slider-wrap {
  width: 100%;
}

.slider-hint-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.slider-hint {
  font-size: 22rpx;
  color: #AEAEB2;
}

.prob-slider {
  width: 100%;
  margin: 0;
}

.slider-scale-row {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.scale-label {
  font-size: 20rpx;
  color: #AEAEB2;
  font-family: -apple-system, "SF Mono", monospace;
}

/* ===== SIMULATION PHASE ===== */
.simulation-phase {
  padding-top: 32rpx;
}

.sim-header {
  width: 100%;
  text-align: center;
  margin-bottom: 32rpx;
}

.sim-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 12rpx;
}

.sim-title.done {
  color: #30D158;
}

.sim-scenario-q {
  font-size: 26rpx;
  color: #86868B;
  line-height: 1.6;
  padding: 0 16rpx;
}

.sim-progress-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.sim-progress-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.sim-progress-label {
  font-size: 26rpx;
  color: #86868B;
}

.sim-progress-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  font-family: -apple-system, "SF Mono", monospace;
}

.sim-bar-bg {
  width: 100%;
  height: 16rpx;
  background: #E5E5EA;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.sim-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #30D158, #00C7BE);
  border-radius: 8rpx;
  transition: width 0.1s linear;
}

.sim-result-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
}

.sim-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.sim-stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1D1D1F;
  font-family: -apple-system, "SF Mono", monospace;
  line-height: 1.2;
}

.sim-stat-num.mono {
  color: #30D158;
}

.sim-stat.success .sim-stat-num {
  color: #30D158;
}

.sim-stat-label {
  font-size: 22rpx;
  color: #86868B;
  margin-top: 6rpx;
}

.sim-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E5EA;
  flex-shrink: 0;
}

/* Comparison card */
.comparison-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 36rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.comparison-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.comparison-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.comp-label {
  font-size: 24rpx;
  color: #86868B;
  margin-bottom: 8rpx;
}

.comp-value {
  font-size: 52rpx;
  font-weight: 700;
  font-family: -apple-system, "SF Mono", monospace;
}

.comp-value.estimate {
  color: #1D1D1F;
}

.comp-value.actual {
  color: #30D158;
}

.comparison-vs {
  font-size: 24rpx;
  color: #AEAEB2;
  font-weight: 600;
  padding: 0 16rpx;
}

.diff-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.diff-label {
  font-size: 26rpx;
  color: #86868B;
}

.diff-value {
  font-size: 30rpx;
  font-weight: 700;
  font-family: -apple-system, "SF Mono", monospace;
}

/* Score popup */
.score-popup {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 8rpx;
}

.score-popup-inner {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.10);
  padding: 28rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-popup-label {
  font-size: 24rpx;
  color: #86868B;
  margin-bottom: 6rpx;
}

.score-popup-value {
  font-size: 72rpx;
  font-weight: 800;
  font-family: -apple-system, "SF Mono", monospace;
  line-height: 1.1;
}

.sim-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 8rpx;
}

.round-progress-text {
  font-size: 26rpx;
  color: #86868B;
  margin-bottom: 4rpx;
}

/* ===== RESULT PHASE ===== */
.result-phase {
  padding-top: 48rpx;
}

.result-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-rating-badge {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.15);
}

.rating-label {
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.rating-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 12rpx;
}

.total-score {
  font-size: 100rpx;
  font-weight: 800;
  color: #1D1D1F;
  font-family: -apple-system, "SF Mono", monospace;
  line-height: 1.1;
}

.score-unit {
  font-size: 44rpx;
  color: #86868B;
  font-weight: 500;
}

.score-max {
  font-size: 26rpx;
  color: #AEAEB2;
  margin-top: 4rpx;
}

.best-record-row {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.new-best-badge {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9F0A;
  background: rgba(255, 159, 10, 0.12);
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
}

.best-record-text {
  font-size: 26rpx;
  color: #86868B;
}

/* Breakdown */
.breakdown-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  padding: 32rpx 36rpx;
  box-sizing: border-box;
  margin-bottom: 12rpx;
}

.breakdown-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.breakdown-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.breakdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}

.breakdown-item:last-child {
  border-bottom: none;
}

.breakdown-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 16rpx;
  margin-right: 16rpx;
}

.breakdown-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.breakdown-info {
  flex: 1;
}

.breakdown-q {
  font-size: 24rpx;
  color: #3C3C43;
  line-height: 1.5;
  margin-bottom: 6rpx;
}

.breakdown-stats {
  font-size: 22rpx;
  color: #86868B;
  line-height: 1.4;
}

.bd-estimate,
.bd-actual {
  color: #86868B;
}

.bd-sep {
  color: #AEAEB2;
}

.bd-diff {
  font-weight: 600;
  font-family: -apple-system, "SF Mono", monospace;
}

.breakdown-score {
  font-size: 32rpx;
  font-weight: 800;
  font-family: -apple-system, "SF Mono", monospace;
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: right;
}

/* Result actions */
.result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 8rpx;
}

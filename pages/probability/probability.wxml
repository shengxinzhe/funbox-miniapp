<view class="page">

  <!-- ===== HOME PHASE ===== -->
  <view class="phase home-phase" wx:if="{{phase === 'home'}}">
    <view class="home-hero">
      <view class="hero-icon">🧪</view>
      <view class="hero-title">概率直觉</view>
      <view class="hero-subtitle">概率感知实验</view>
    </view>

    <view class="home-desc-card">
      <view class="home-desc-item">
        <view class="desc-icon">🎯</view>
        <view class="desc-text">8道概率题目，用滑块估算概率</view>
      </view>
      <view class="home-desc-item">
        <view class="desc-icon">🔬</view>
        <view class="desc-text">500次模拟实验，揭示真实概率</view>
      </view>
      <view class="home-desc-item">
        <view class="desc-icon">⭐</view>
        <view class="desc-text">越精准得分越高，最高800分</view>
      </view>
    </view>

    <view class="best-score-row" wx:if="{{bestScore > 0}}">
      <view class="best-label">最高分</view>
      <view class="best-value">{{bestScore}}</view>
    </view>

    <button class="btn-primary" bindtap="startGame">开始实验</button>
  </view>

  <!-- ===== QUESTION PHASE ===== -->
  <view class="phase question-phase" wx:if="{{phase === 'question'}}">
    <view class="round-indicator">
      <view class="round-dots">
        <block wx:for="{{scenarios}}" wx:key="id">
          <view class="round-dot {{index < roundIndex ? 'done' : (index === roundIndex ? 'active' : '')}}"></view>
        </block>
      </view>
      <view class="round-text">第 {{roundIndex + 1}} / 8 题</view>
    </view>

    <view class="scenario-card" wx:if="{{currentScenario}}">
      <view class="scenario-icon">{{currentScenario.icon}}</view>
      <view class="scenario-question">{{currentScenario.q}}</view>
      <view class="scenario-cat-badge">{{currentScenario.cat}}</view>
    </view>

    <view class="estimate-section">
      <view class="estimate-label">你的估算</view>
      <view class="estimate-value">{{displayValue}}<text class="estimate-pct">%</text></view>

      <view class="slider-wrap">
        <view class="slider-hint-row">
          <text class="slider-hint">不可能</text>
          <text class="slider-hint">必然发生</text>
        </view>
        <slider
          class="prob-slider"
          min="0"
          max="100"
          step="1"
          value="{{sliderValue}}"
          activeColor="#30D158"
          backgroundColor="#E5E5EA"
          block-color="#FFFFFF"
          block-size="28"
          bindchange="onSliderChange"
          bindchanging="onSliderChanging"
        />
        <view class="slider-scale-row">
          <text class="scale-label">0%</text>
          <text class="scale-label">25%</text>
          <text class="scale-label">50%</text>
          <text class="scale-label">75%</text>
          <text class="scale-label">100%</text>
        </view>
      </view>
    </view>

    <button class="btn-primary" bindtap="confirmEstimate">确 认</button>
  </view>

  <!-- ===== SIMULATION PHASE ===== -->
  <view class="phase simulation-phase" wx:if="{{phase === 'simulation'}}">
    <view class="sim-header">
      <view class="sim-title" wx:if="{{!simDone}}">模拟实验中...</view>
      <view class="sim-title done" wx:if="{{simDone}}">实验完成！</view>
      <view class="sim-scenario-q" wx:if="{{currentScenario}}">{{currentScenario.q}}</view>
    </view>

    <!-- Progress Bar -->
    <view class="sim-progress-card">
      <view class="sim-progress-label-row">
        <text class="sim-progress-label">实验进度</text>
        <text class="sim-progress-count">{{simCount}} / {{simTotal}} 次</text>
      </view>
      <view class="sim-bar-bg">
        <view class="sim-bar-fill" style="width: {{simPercent}}%"></view>
      </view>

      <view class="sim-result-row">
        <view class="sim-stat success">
          <view class="sim-stat-num">{{simSuccess}}</view>
          <view class="sim-stat-label">成功次数</view>
        </view>
        <view class="sim-stat-divider"></view>
        <view class="sim-stat neutral">
          <view class="sim-stat-num mono">{{simSuccessPercent}}%</view>
          <view class="sim-stat-label">实际概率</view>
        </view>
      </view>
    </view>

    <!-- Comparison (shown after sim done) -->
    <view class="comparison-card" wx:if="{{simDone}}">
      <view class="comparison-row">
        <view class="comparison-item">
          <view class="comp-label">你的估算</view>
          <view class="comp-value estimate">{{playerEstimate}}%</view>
        </view>
        <view class="comparison-vs">VS</view>
        <view class="comparison-item">
          <view class="comp-label">真实概率</view>
          <view class="comp-value actual">{{actualAnswer}}%</view>
        </view>
      </view>
      <view class="diff-row">
        <text class="diff-label">误差</text>
        <text class="diff-value" style="color: {{roundScoreColor}}">±{{diffValue}}%</text>
      </view>
    </view>

    <!-- Score popup -->
    <view class="score-popup" wx:if="{{simDone}}">
      <view class="score-popup-inner">
        <view class="score-popup-label">本题得分</view>
        <view class="score-popup-value" style="color: {{roundScoreColor}}">+{{roundScore}}</view>
      </view>
    </view>

    <view class="sim-actions" wx:if="{{simDone}}">
      <view class="round-progress-text">第 {{roundIndex + 1}} / 8 题完成</view>
      <button class="btn-primary" bindtap="nextRound" wx:if="{{roundIndex < 7}}">下一题 →</button>
      <button class="btn-primary" bindtap="nextRound" wx:if="{{roundIndex >= 7}}">查看结果 →</button>
    </view>
  </view>

  <!-- ===== RESULT PHASE ===== -->
  <view class="phase result-phase" wx:if="{{phase === 'result'}}">
    <view class="result-hero">
      <view class="result-rating-badge" style="background: {{ratingColor}}">
        <view class="rating-label">{{ratingLabel}}</view>
      </view>
      <view class="rating-title">{{ratingTitle}}</view>
      <view class="total-score">{{totalScore}} <text class="score-unit">分</text></view>
      <view class="score-max">满分 800 分</view>
    </view>

    <view class="best-record-row" wx:if="{{totalScore >= bestScore}}">
      <view class="new-best-badge">🏆 新纪录！</view>
    </view>
    <view class="best-record-row" wx:else>
      <view class="best-record-text">最高分：{{bestScore}} 分</view>
    </view>

    <!-- Round breakdown -->
    <view class="breakdown-card">
      <view class="breakdown-title">答题详情</view>
      <view class="breakdown-list">
        <view class="breakdown-item" wx:for="{{roundResults}}" wx:key="round">
          <view class="breakdown-left">
            <view class="breakdown-icon">{{item.icon}}</view>
            <view class="breakdown-info">
              <view class="breakdown-q">{{item.question}}</view>
              <view class="breakdown-stats">
                <text class="bd-estimate">估算 {{item.estimate}}%</text>
                <text class="bd-sep"> · </text>
                <text class="bd-actual">实际 {{item.actual}}%</text>
                <text class="bd-sep"> · </text>
                <text class="bd-diff" style="color: {{item.scoreColor}}">误差 ±{{item.diff}}%</text>
              </view>
            </view>
          </view>
          <view class="breakdown-score" style="color: {{item.scoreColor}}">+{{item.score}}</view>
        </view>
      </view>
    </view>

    <view class="result-actions">
      <button class="btn-primary" bindtap="playAgain">再来一次</button>
      <button class="btn-secondary" bindtap="goHome">返回首页</button>
    </view>
  </view>

</view>

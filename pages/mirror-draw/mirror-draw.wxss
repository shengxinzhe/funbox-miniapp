/* mirror-draw.wxss */

/* ── Base ── */
page {
  background: #F5F5F7;
  font-family: -apple-system, "PingFang SC", sans-serif;
}

.page-container {
  min-height: 100vh;
  background: #F5F5F7;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.screen {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 60rpx;
  box-sizing: border-box;
}

/* ── INTRO ── */
.intro-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  margin-top: 24rpx;
}

.intro-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(88, 86, 214, 0.35);
}

.intro-icon {
  font-size: 64rpx;
  line-height: 1;
}

.intro-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -1rpx;
}

.intro-subtitle {
  font-size: 28rpx;
  color: #86868B;
  margin-top: 8rpx;
}

.intro-desc {
  font-size: 26rpx;
  color: #86868B;
  text-align: center;
  margin-top: 16rpx;
  line-height: 1.6;
  white-space: pre-line;
}

/* ── Mode Cards ── */
.mode-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mode-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: transform 0.15s;
}

.mode-card:active {
  transform: scale(0.98);
}

.mode-card.locked {
  opacity: 0.5;
}

.mode-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.mode-icon {
  font-size: 48rpx;
  line-height: 1;
}

.mode-info {
  display: flex;
  flex-direction: column;
}

.mode-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.mode-desc {
  font-size: 22rpx;
  color: #86868B;
  margin-top: 4rpx;
}

.mode-card-right {
  display: flex;
  align-items: center;
}

.stars-row {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #D1D1D6;
}

.star.filled {
  color: #FF9F0A;
}

.lock-icon {
  font-size: 32rpx;
}

/* ── GAME SCREEN ── */
.game-screen {
  padding: 24rpx 24rpx 40rpx;
}

.hud-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.hud-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hud-item.center {
  align-items: center;
}

.hud-item.right {
  align-items: flex-end;
}

.hud-label {
  font-size: 20rpx;
  color: #86868B;
}

.hud-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-top: 2rpx;
}

.hud-value.timer {
  color: #5856D6;
  font-variant-numeric: tabular-nums;
}

.shape-name-bar {
  margin-bottom: 16rpx;
}

.shape-name {
  font-size: 26rpx;
  color: #86868B;
}

/* ── Canvas ── */
.canvas-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.draw-canvas {
  width: 600rpx;
  height: 600rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.08);
  display: block;
}

.canvas-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.hint-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  display: inline-block;
}

.finger-dot {
  background: rgba(255, 149, 0, 0.7);
  border: 2rpx solid #FF9500;
}

.draw-dot {
  background: #5856D6;
}

.hint-text {
  font-size: 20rpx;
  color: #86868B;
  margin-right: 16rpx;
}

/* ── Controls ── */
.controls-row {
  width: 100%;
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: transform 0.1s, opacity 0.1s;
}

.btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn-ghost {
  background: #FFFFFF;
  color: #1D1D1F;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(88, 86, 214, 0.35);
}

/* ── RESULT SCREEN ── */
.result-screen {
  padding: 32rpx 24rpx 60rpx;
}

.result-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 24rpx rgba(0,0,0,0.07);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 28rpx;
}

.score-circle-wrap {
  margin-bottom: 20rpx;
}

.score-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid #E5E5EA;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: row;
  background: #F5F5F7;
  transition: border-color 0.4s;
}

.score-circle.great {
  border-color: #34C759;
  background: rgba(52, 199, 89, 0.06);
}

.score-circle.good {
  border-color: #FF9F0A;
  background: rgba(255, 159, 10, 0.06);
}

.score-circle.poor {
  border-color: #FF3B30;
  background: rgba(255, 59, 48, 0.06);
}

.score-number {
  font-size: 72rpx;
  font-weight: 800;
  color: #1D1D1F;
  font-variant-numeric: tabular-nums;
}

.score-pct {
  font-size: 30rpx;
  font-weight: 600;
  color: #86868B;
  margin-top: 20rpx;
}

.result-stars {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.result-star {
  font-size: 52rpx;
  color: #D1D1D6;
  transition: color 0.3s, transform 0.3s;
}

.result-star.lit {
  color: #FF9F0A;
  transform: scale(1.15);
}

.result-label {
  font-size: 28rpx;
  color: #86868B;
  margin-bottom: 28rpx;
}

.compare-canvas-wrap {
  margin-bottom: 8rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.06);
}

.compare-canvas {
  width: 400rpx;
  height: 400rpx;
  background: #F5F5F7;
  display: block;
}

.compare-legend {
  font-size: 22rpx;
  color: #86868B;
  margin-bottom: 28rpx;
  display: flex;
  gap: 16rpx;
}

.result-btns {
  width: 100%;
  display: flex;
  gap: 16rpx;
}

/* ── MODE COMPLETE ── */
.mode-complete-screen {
  padding: 32rpx 24rpx 60rpx;
}

.complete-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 24rpx rgba(0,0,0,0.07);
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.complete-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.complete-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1D1D1F;
}

.complete-mode-name {
  font-size: 26rpx;
  color: #5856D6;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.complete-stats {
  display: flex;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #1D1D1F;
}

.stat-label {
  font-size: 22rpx;
  color: #86868B;
  margin-top: 4rpx;
}

/* Shape grid */
.shape-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.shape-cell {
  background: #F5F5F7;
  border-radius: 12rpx;
  padding: 12rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.cell-num {
  font-size: 22rpx;
  color: #86868B;
}

.cell-stars {
  display: flex;
}

.cs {
  font-size: 18rpx;
  color: #D1D1D6;
}

.cs.lit {
  color: #FF9F0A;
}

/* Unlock banner */
.unlock-banner {
  width: 100%;
  background: linear-gradient(135deg, rgba(88,86,214,0.1), rgba(175,82,222,0.1));
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  text-align: center;
  margin-bottom: 24rpx;
  animation: unlockPulse 1.2s ease-in-out infinite alternate;
}

@keyframes unlockPulse {
  from { opacity: 0.8; }
  to { opacity: 1; }
}

.unlock-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #5856D6;
}

.complete-btns {
  width: 100%;
  display: flex;
  gap: 16rpx;
}

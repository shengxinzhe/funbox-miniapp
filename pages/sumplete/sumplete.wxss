/* sumplete.wxss */

.page-container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 32rpx 60rpx;
  box-sizing: border-box;
}

.screen { padding-top: 40rpx; }

/* ─── INTRO ─── */
.intro-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}
.intro-icon-wrap {
  width: 120rpx; height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(88,86,214,0.25);
}
.intro-icon { font-size: 56rpx; }
.intro-title {
  font-size: 44rpx; font-weight: 700;
  color: #1C1C1E; margin-bottom: 8rpx;
}
.intro-subtitle {
  font-size: 28rpx; color: #86868B;
  margin-bottom: 8rpx;
}
.intro-desc {
  font-size: 24rpx; color: #AEAEB2;
  text-align: center; line-height: 1.6;
}

/* Difficulty list */
.diff-list {
  display: flex; flex-direction: column; gap: 20rpx;
  margin-bottom: 32rpx;
}
.diff-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  border: 3rpx solid transparent;
  transition: border-color 0.2s;
}
.diff-card.selected {
  border-color: #5856D6;
}
.diff-left { display: flex; flex-direction: column; }
.diff-label {
  font-size: 34rpx; font-weight: 600; color: #1C1C1E;
}
.diff-desc {
  font-size: 24rpx; color: #86868B; margin-top: 4rpx;
}
.diff-right {
  display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx;
}
.diff-best { display: flex; gap: 8rpx; align-items: center; }
.best-label { font-size: 22rpx; color: #AEAEB2; }
.best-val { font-size: 24rpx; font-weight: 600; color: #5856D6; }
.diff-stars { display: flex; gap: 4rpx; }
.star { font-size: 28rpx; color: #D1D1D6; }
.star.filled { color: #FF9F0A; }

/* How to play */
.how-to-play {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.how-title {
  font-size: 28rpx; font-weight: 600; color: #1C1C1E;
  display: block; margin-bottom: 12rpx;
}
.how-text {
  font-size: 24rpx; color: #86868B; line-height: 1.7;
}

/* Start button */
.start-btn {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF;
  font-size: 32rpx; font-weight: 600;
  border-radius: 48rpx;
  height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(88,86,214,0.25);
}

/* ─── GAME ─── */
.hud-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.hud-item { display: flex; flex-direction: column; }
.hud-item.center { align-items: center; }
.hud-item.right { align-items: flex-end; }
.hud-label { font-size: 22rpx; color: #AEAEB2; }
.hud-value { font-size: 30rpx; font-weight: 600; color: #1C1C1E; }

/* Grid area */
.grid-area {
  display: flex; justify-content: center;
  margin-bottom: 32rpx;
}
.grid-table {
  display: flex; flex-direction: column;
  gap: 6rpx;
}
.grid-row {
  display: flex; gap: 6rpx;
}

/* Cell sizing based on grid size via CSS custom property not supported in WXSS,
   so we use a fixed approach that scales reasonably */
.grid-cell {
  background: #FFFFFF;
  border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06);
  transition: background-color 0.15s, transform 0.1s;
}
.grid-cell:active { transform: scale(0.93); }

.cell-num {
  font-size: 32rpx; font-weight: 600; color: #1C1C1E;
  z-index: 1;
}
.cell-mark {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 700;
  z-index: 2;
}

/* Deleted state */
.grid-cell.deleted {
  background: #FFF0F0;
}
.grid-cell.deleted .cell-num {
  color: #C7C7CC; text-decoration: line-through;
}
.grid-cell.deleted .cell-mark {
  color: #FF3B30; opacity: 0.7;
}

/* Kept state */
.grid-cell.kept {
  background: #F0FFF4;
}
.grid-cell.kept .cell-num {
  color: #1C1C1E;
}
.grid-cell.kept .cell-mark.keep-mark {
  color: #34C759; opacity: 0.6;
  font-size: 34rpx;
}

/* Target cells */
.target-cell {
  display: flex; align-items: center; justify-content: center;
  border-radius: 12rpx;
}
.row-target {
  background: #F2F2F7;
}
.col-target {
  background: #F2F2F7;
}
.target-cell.matched {
  background: #E8F5E9;
}
.target-cell.matched .target-num {
  color: #34C759;
}
.target-num {
  font-size: 30rpx; font-weight: 700; color: #86868B;
}
.target-cell.corner {
  background: transparent;
}

/* Controls */
.controls-row {
  display: flex; gap: 16rpx;
  justify-content: center;
}
.btn {
  height: 80rpx; padding: 0 36rpx;
  border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600;
}
.btn-ghost {
  background: #FFFFFF;
  color: #5856D6;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}
.btn-primary {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(88,86,214,0.25);
}

/* ─── COMPLETE ─── */
.complete-screen {
  display: flex; align-items: center; justify-content: center;
  min-height: 80vh;
}
.complete-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  width: 100%;
}
.complete-emoji { font-size: 72rpx; margin-bottom: 16rpx; }
.complete-title {
  font-size: 40rpx; font-weight: 700; color: #1C1C1E;
  margin-bottom: 8rpx;
}
.complete-diff {
  font-size: 28rpx; color: #86868B; margin-bottom: 32rpx;
}
.complete-stats {
  display: flex; gap: 60rpx; margin-bottom: 32rpx;
}
.stat-item {
  display: flex; flex-direction: column; align-items: center;
}
.stat-num {
  font-size: 40rpx; font-weight: 700; color: #5856D6;
}
.stat-label {
  font-size: 24rpx; color: #AEAEB2; margin-top: 4rpx;
}
.result-stars {
  display: flex; gap: 12rpx; margin-bottom: 40rpx;
}
.result-star {
  font-size: 52rpx; color: #D1D1D6;
}
.result-star.lit {
  color: #FF9F0A;
}
.complete-btns {
  display: flex; gap: 20rpx; width: 100%;
  justify-content: center;
}

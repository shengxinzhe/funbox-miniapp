.page {
  min-height: 100vh;
  padding: 0 32rpx 60rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.fade-in { opacity: 1; }

/* Intro */
.intro { text-align: center; padding-top: 60rpx; }
.intro-emoji {
  font-size: 120rpx;
  animation: trolleyMove 2s ease-in-out infinite;
}
@keyframes trolleyMove {
  0%,100% { transform: translateX(-20rpx); }
  50% { transform: translateX(20rpx); }
}
.intro-title {
  font-size: 48rpx; font-weight: 800;
  margin-top: 16rpx;
}
.intro-subtitle {
  font-size: 28rpx; color: #e74c3c;
  margin-top: 8rpx; font-weight: 500;
}
.intro-desc {
  font-size: 26rpx; color: #8888a0;
  margin-top: 24rpx; line-height: 1.6;
  padding: 0 32rpx;
}
.intro-stats {
  margin-top: 32rpx;
  display: flex; align-items: baseline;
  justify-content: center; gap: 8rpx;
}
.stats-label { font-size: 26rpx; color: #8888a0; }
.stats-val { font-size: 48rpx; font-weight: 800; color: #e74c3c; }
.start-btn {
  margin-top: 48rpx;
  display: inline-block;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  font-size: 34rpx; font-weight: 700;
  padding: 28rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(231,76,60,0.4);
}
.start-btn:active { transform: scale(0.95); opacity: 0.9; }

/* Playing */
.playing { padding-top: 24rpx; }
.progress-bar {
  height: 8rpx; background: #1a1a2e;
  border-radius: 4rpx; overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e74c3c, #f39c12);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}
.progress-text {
  text-align: center; font-size: 24rpx;
  color: #8888a0; margin-top: 8rpx;
}

/* Problem Card */
.problem-card {
  margin-top: 32rpx;
  background: #14141f;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  opacity: 0;
  transform: translateY(30rpx);
}
.card-enter {
  animation: cardSlide 0.4s ease forwards;
}
@keyframes cardSlide {
  to { opacity: 1; transform: translateY(0); }
}
.scene-emoji {
  font-size: 80rpx; text-align: center;
  margin-bottom: 20rpx;
}
.scene-text {
  font-size: 32rpx; font-weight: 600;
  text-align: center; line-height: 1.5;
  margin-bottom: 36rpx; color: #e0e0f0;
}

/* Options */
.options { display: flex; flex-direction: column; gap: 20rpx; }
.option {
  position: relative;
  background: #1a1a2e;
  border: 2rpx solid #2a2a3e;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex; align-items: flex-start; gap: 16rpx;
  transition: all 0.3s ease;
  overflow: hidden;
}
.option:active { transform: scale(0.98); }
.option-label {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: #2a2a3e;
  display: flex; justify-content: center; align-items: center;
  font-size: 24rpx; font-weight: 700;
  flex-shrink: 0;
}
.option-text {
  font-size: 28rpx; line-height: 1.5;
  color: #c0c0d0; flex: 1;
}

/* Chosen states */
.option.chosen.option-a {
  border-color: #e74c3c;
  background: rgba(231,76,60,0.1);
}
.option.chosen.option-a .option-label {
  background: #e74c3c; color: #fff;
}
.option.chosen.option-b {
  border-color: #3498db;
  background: rgba(52,152,219,0.1);
}
.option.chosen.option-b .option-label {
  background: #3498db; color: #fff;
}
.option.not-chosen {
  opacity: 0.5;
}

/* Vote bar */
.vote-bar {
  position: absolute;
  left: 0; bottom: 0;
  height: 4rpx;
  border-radius: 2rpx;
  transition: width 0.6s ease;
}
.option-a .vote-bar { background: #e74c3c; }
.option-b .vote-bar { background: #3498db; }
.vote-pct {
  position: absolute;
  right: 24rpx; top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx; font-weight: 700;
  color: #8888a0;
  animation: pctFade 0.4s ease forwards;
}
@keyframes pctFade {
  from { opacity: 0; transform: translateY(-50%) scale(0.8); }
  to { opacity: 1; transform: translateY(-50%) scale(1); }
}

/* Next button */
.next-btn {
  margin-top: 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  font-size: 30rpx; font-weight: 600;
  padding: 24rpx 0;
  border-radius: 48rpx;
  animation: btnAppear 0.3s ease forwards;
}
@keyframes btnAppear {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.next-btn:active { opacity: 0.85; }

/* Result */
.result { text-align: center; padding-top: 48rpx; }
.result-emoji {
  font-size: 120rpx;
  animation: resultPop 0.5s ease;
}
@keyframes resultPop {
  0% { transform: scale(0); }
  60% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.result-title {
  font-size: 44rpx; font-weight: 800;
  margin-top: 16rpx;
}
.result-subtitle {
  font-size: 28rpx; color: #8888a0;
  margin-top: 8rpx;
}

/* Summary */
.result-summary {
  display: flex; flex-wrap: wrap;
  justify-content: center; gap: 16rpx;
  margin-top: 36rpx; padding: 0 16rpx;
}
.summary-item {
  background: #14141f;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  display: flex; align-items: center; gap: 8rpx;
}
.summary-num { font-size: 22rpx; color: #8888a0; }
.summary-choice { font-size: 24rpx; font-weight: 600; }
.choice-a { color: #e74c3c; }
.choice-b { color: #3498db; }

/* Streak */
.result-streak {
  margin-top: 32rpx;
  font-size: 30rpx; color: #f39c12;
  font-weight: 600;
}
.streak-icon { margin-right: 8rpx; }

/* Actions */
.result-actions {
  display: flex; justify-content: center;
  align-items: center; gap: 24rpx;
  margin-top: 40rpx;
}
.action-btn {
  font-size: 30rpx; font-weight: 600;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
}
.retry-btn {
  background: #14141f; color: #e0e0f0;
  border: 2rpx solid #2a2a3e;
}
.retry-btn:active { background: #1a1a2e; }
.share-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b) !important;
  color: #fff !important;
  margin: 0; min-height: 0;
  line-height: 1.5;
}
.share-btn::after { border: none; }
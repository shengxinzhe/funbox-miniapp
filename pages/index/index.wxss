.page {
  padding: 0 32rpx 60rpx;
  min-height: 100vh;
  background: #F5F5F7;
  color: #1D1D1F;
}

/* Header */
.header {
  padding: 48rpx 0 36rpx;
  text-align: center;
}

.logo {
  font-size: 56rpx;
  font-weight: 800;
  color: #1D1D1F;
  letter-spacing: -2rpx;
}

.accent {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  -webkit-background-clip: text;
  color: transparent;
}

.tagline {
  font-size: 26rpx;
  color: #86868B;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* Section */
.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #86868B;
  letter-spacing: 1rpx;
  margin: 28rpx 0 16rpx 8rpx;
  text-transform: uppercase;
}

/* Game Grid */
.grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease;
}

.card:active {
  transform: scale(0.97);
}

.card-icon {
  font-size: 44rpx;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  margin-left: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #86868B;
  line-height: 1.5;
}

.card-arrow {
  font-size: 28rpx;
  color: #C7C7CC;
  margin-left: 8rpx;
  font-weight: 300;
}

/* Share */
.share-hint {
  margin-top: 40rpx;
  text-align: center;
}

.share-btn {
  display: inline-block;
  background: #FFFFFF !important;
  color: #5856D6 !important;
  border: none !important;
  border-radius: 48rpx !important;
  padding: 20rpx 48rpx !important;
  font-size: 28rpx !important;
  font-weight: 500;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.06);
  line-height: 1.5 !important;
}

.share-btn::after {
  border: none !important;
}

/* Footer */
.footer {
  text-align: center;
  padding: 40rpx 0 32rpx;
  font-size: 22rpx;
  color: #AEAEB2;
}

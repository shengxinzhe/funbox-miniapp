.page {
  padding: 0 32rpx 60rpx;
  min-height: 100vh;
}

/* Header */
.header {
  padding: 40rpx 0 16rpx;
  text-align: center;
}

.logo {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
}

.accent {
  color: #6c63ff;
}

.tagline {
  font-size: 26rpx;
  color: #8888a0;
  margin-top: 4rpx;
}

/* Game Grid */
.grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  display: flex;
  align-items: center;
  background: #14141f;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  transition: all 0.2s;
}

.card:active {
  background: #1a1a2e;
  transform: scale(0.98);
}

.card-icon {
  font-size: 56rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(108, 99, 255, 0.1);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  margin-left: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #8888a0;
  line-height: 1.4;
}

.card-arrow {
  font-size: 28rpx;
  color: #8888a0;
  margin-left: 12rpx;
}

/* Share */
.share-hint {
  margin-top: 48rpx;
  text-align: center;
}

.share-btn {
  display: inline-block;
  background: rgba(108, 99, 255, 0.12);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.25);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.5;
}

.share-btn::after {
  border: none;
}

/* Footer */
.footer {
  text-align: center;
  padding: 48rpx 0 32rpx;
  font-size: 22rpx;
  color: #555;
}

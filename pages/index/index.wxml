<view class="page">
  <!-- Header -->
  <view class="header">
    <view class="logo">Fun<text class="accent">Box</text></view>
    <view class="tagline">有趣的小实验</view>
  </view>

  <!-- Hero -->
  <view class="hero">
    <view class="hero-title">用小游戏，打发无聊时光</view>
    <view class="hero-desc">免费 / 即开即玩 / 不用注册</view>
  </view>

  <!-- Game Grid -->
  <view class="grid">
    <view
      class="card"
      wx:for="{{games}}"
      wx:key="id"
      bindtap="openGame"
      data-page="{{item.page}}"
    >
      <view class="card-icon" style="background: {{item.color}}20;">{{item.icon}}</view>
      <view class="card-info">
        <view class="card-title">{{item.title}}</view>
        <view class="card-desc">{{item.desc}}</view>
      </view>
      <view class="card-arrow">></view>
    </view>
  </view>

  <!-- Share hint -->
  <view class="share-hint">
    <button class="share-btn" open-type="share">
      分享给朋友一起玩
    </button>
  </view>

  <!-- Footer -->
  <view class="footer">
    <text>FunBox - 用小游戏打发无聊时光</text>
  </view>
</view>

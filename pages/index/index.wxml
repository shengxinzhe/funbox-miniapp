<view class="page">
  <!-- Header -->
  <view class="header">
    <view class="logo">智变<text class="accent">纪</text></view>
    <view class="tagline">趣味实验室</view>
  </view>

  <!-- Game Grid -->
  <view class="grid">
    <view
      class="card"
      wx:for="{{games}}"
      wx:key="id"
      bindtap="openGame"
      data-page="{{item.page}}"
    >
      <view class="card-icon" style="background: {{item.color}}12;">{{item.icon}}</view>
      <view class="card-info">
        <view class="card-title">{{item.title}}</view>
        <view class="card-desc">{{item.desc}}</view>
      </view>
      <view class="card-arrow"></view>
    </view>
  </view>

  <!-- Share hint -->
  <view class="share-hint">
    <button class="share-btn" open-type="share">
      分享给朋友一起玩
    </button>
  </view>

  <!-- Footer -->
  <view class="footer">
    <text>关注公众号「智变纪」获取更多AI时代趣味内容</text>
  </view>
</view>

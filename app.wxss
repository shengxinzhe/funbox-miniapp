/* Global Styles - Apple Light Theme */
page {
  background: #F5F5F7;
  color: #1D1D1F;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Common utility */
.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.text-center {
  text-align: center;
}

.btn-primary {
  background: linear-gradient(135deg, #5856D6, #AF52DE);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.card-bg {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}
